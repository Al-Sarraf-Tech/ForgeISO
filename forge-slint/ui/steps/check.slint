import { Palette, Sizes } from "../theme.slint";
import { FButton, FCard, FBadge, FDivider, FTextInput } from "../components/design_system.slint";

component ResultCard inherits FCard {
    in property <bool>   passed;
    in property <bool>   has-result;
    in property <string> result-title;
    in property <string> detail;

    border-color: !has-result ? Palette.border
               : passed ? rgba(69, 194, 107, 0.4)
               : rgba(240, 82, 75, 0.4);
    background: !has-result ? Palette.surface
              : passed ? rgba(69, 194, 107, 0.06)
              : rgba(240, 82, 75, 0.06);

    animate background { duration: 250ms; }
    animate border-color { duration: 250ms; }

    VerticalLayout {
        padding: Sizes.space-4;
        spacing: Sizes.space-2;
        HorizontalLayout {
            spacing: Sizes.space-2;
            alignment: start;
            if has-result: FBadge {
                text: passed ? "PASS" : "FAIL";
                variant: passed ? "success" : "error";
            }
            if !has-result: FBadge {
                text: "PENDING";
                variant: "default";
            }
            Text {
                text: result-title;
                font-size: Sizes.font-md;
                font-weight: 700;
                color: !has-result ? Palette.muted
                     : passed ? Palette.green
                     : Palette.red;
                vertical-alignment: center;
            }
        }
        if detail != "": Text {
            text: detail;
            font-size: Sizes.font-sm;
            color: Palette.muted;
            wrap: word-wrap;
        }
    }
}

export component StepCheck inherits Rectangle {
    // Source
    in-out property <string> verify-source;
    in-out property <string> sums-url;

    // Inject artifact (auto-filled)
    in property <string>  artifact-path;
    in property <string>  artifact-sha256;

    // Verify result
    in property <bool>    verify-done;
    in property <bool>    verify-matched;
    in property <string>  verify-hash-display;

    // ISO-9660 result
    in property <bool>    iso9660-done;
    in property <bool>    iso9660-compliant;
    in property <bool>    iso9660-boot-bios;
    in property <bool>    iso9660-boot-uefi;
    in property <string>  iso9660-volume-id;

    in property <bool>    running;

    // Output self-check
    in property <bool>    output-verified;
    in property <bool>    output-verify-matched;

    callback back-clicked();
    callback browse-verify-source();
    callback run-verify();
    callback run-iso9660();
    callback run-verify-output();
    callback copy-sha256();
    callback open-folder();
    callback clear-forms();

    background: Palette.bg;

    VerticalLayout {
        padding: Sizes.space-10;
        spacing: Sizes.space-8;
        alignment: start;

        // ── Title ────────────────────────────────────────────────────
        HorizontalLayout {
            spacing: Sizes.space-3;
            alignment: space-between;
            VerticalLayout {
                spacing: Sizes.space-1;
                Text {
                    text: "Optional Checks";
                    font-size: Sizes.font-2xl;
                    font-weight: 700;
                    color: Palette.text;
                }
                Text {
                    text: "Your ISO is already ready to use. Run checksum or ISO-9660 checks only if you want extra validation.";
                    font-size: Sizes.font-sm;
                    color: Palette.muted;
                }
            }
            HorizontalLayout {
                spacing: Sizes.space-2;
                alignment: end;

                FButton {
                    label: "← Back to Build";
                    variant: "secondary";
                    enabled: !running;
                    clicked => { back-clicked(); }
                }

                FBadge {
                    text: "Optional";
                    variant: "default";
                }
            }
        }

        // ── Build success banner ─────────────────────────────────────
        if artifact-path != "": FCard {
            border-color: rgba(69, 194, 107, 0.35);
            background: rgba(69, 194, 107, 0.05);

            VerticalLayout {
                padding: Sizes.space-5;
                spacing: Sizes.space-3;

                HorizontalLayout {
                    spacing: Sizes.space-3;
                    alignment: start;
                    Text {
                        text: "✓";
                        font-size: 22px;
                        color: Palette.green;
                        vertical-alignment: center;
                    }
                    VerticalLayout {
                        spacing: 2px;
                        Text {
                            text: "Build complete — verification optional";
                            font-size: Sizes.font-lg;
                            font-weight: 700;
                            color: Palette.green;
                        }
                        Text {
                            text: artifact-path;
                            font-size: Sizes.font-sm;
                            color: Palette.muted;
                            overflow: elide;
                        }
                    }
                }

                if artifact-sha256 != "": Text {
                    text: "SHA-256: " + artifact-sha256;
                    font-size: Sizes.font-xs;
                    font-family: "monospace";
                    color: Palette.muted;
                }

                FDivider {}

                HorizontalLayout {
                    spacing: Sizes.space-2;
                    alignment: start;

                    FButton {
                        label: "＋ Start New Build";
                        variant: "primary";
                        enabled: !running;
                        clicked => { clear-forms(); }
                    }

                    FButton {
                        label: "Copy SHA-256";
                        icon: "📋";
                        variant: "secondary";
                        clicked => { copy-sha256(); }
                    }

                    FButton {
                        label: "Open Folder";
                        icon: "📂";
                        variant: "secondary";
                        clicked => { open-folder(); }
                    }
                }
            }
        }

        // ── Output ISO Integrity ────────────────────────────────────
        if artifact-path != "" && artifact-sha256 != "": FCard {
            title: "OUTPUT ISO INTEGRITY";
            VerticalLayout {
                padding: Sizes.space-5;
                spacing: Sizes.space-3;

                Text {
                    text: "Share this hash so others can verify your ISO is authentic and unmodified.";
                    font-size: Sizes.font-sm;
                    color: Palette.muted;
                    wrap: word-wrap;
                }

                // Hash display
                Rectangle {
                    height: 36px;
                    border-radius: Sizes.radius-sm;
                    background: Palette.bg;
                    border-width: 1px;
                    border-color: Palette.border-subtle;
                    HorizontalLayout {
                        padding-left: Sizes.space-3;
                        padding-right: Sizes.space-3;
                        alignment: start;
                        Text {
                            text: artifact-sha256;
                            font-size: Sizes.font-xs;
                            font-family: "monospace";
                            color: Palette.text;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }

                HorizontalLayout {
                    spacing: Sizes.space-2;
                    alignment: start;

                    FButton {
                        label: "Copy Hash";
                        variant: "secondary";
                        clicked => { copy-sha256(); }
                    }

                    FButton {
                        label: "Verify Write Integrity";
                        variant: output-verified && output-verify-matched ? "secondary" : "primary";
                        enabled: !running;
                        clicked => { run-verify-output(); }
                    }
                }

                if output-verified: ResultCard {
                    has-result: true;
                    passed: output-verify-matched;
                    result-title: output-verify-matched ? "Output ISO integrity confirmed" : "Output hash mismatch — possible write error";
                    detail: output-verify-matched
                        ? "Re-read the ISO file and recomputed SHA-256. Matches the build hash."
                        : "The file on disk differs from what was written. Check disk space or filesystem errors.";
                }
            }
        }

        // ── Source Checksum Verification ─────────────────────────────
        FCard {
            title: "SOURCE ISO VERIFICATION";
            VerticalLayout {
                padding: Sizes.space-5;
                spacing: Sizes.space-4;

                Text {
                    text: "Verify a source ISO against the distro's published upstream checksums (SHA256SUMS).";
                    font-size: Sizes.font-sm;
                    color: Palette.muted;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: Sizes.space-2;
                    FTextInput {
                        value <=> verify-source;
                        hint: "/path/to/output.iso  or  https://…";
                        enabled: !running;
                        changed(v) => { verify-source = v; }
                    }
                    FButton {
                        label: "Browse…";
                        variant: "secondary";
                        enabled: !running;
                        clicked => { browse-verify-source(); }
                    }
                }

                FTextInput {
                    value <=> sums-url;
                    hint: "SHA256SUMS URL or file path (optional)";
                    enabled: !running;
                    changed(v) => { sums-url = v; }
                }

                HorizontalLayout {
                    spacing: Sizes.space-3;
                    alignment: start;

                    FButton {
                        label: "Check File Integrity";
                        icon: "🔍";
                        variant: "primary";
                        enabled: verify-source != "" && !running;
                        clicked => { run-verify(); }
                    }

                    FButton {
                        label: "ISO-9660 Layout";
                        icon: "📋";
                        variant: "secondary";
                        enabled: verify-source != "" && !running;
                        clicked => { run-iso9660(); }
                    }
                }

                FDivider {}

                // Results
                if !verify-done && !iso9660-done: FCard {
                    drop-shadow-blur: 0px;
                    background: Palette.elevated;

                    VerticalLayout {
                        padding: Sizes.space-4;
                        spacing: Sizes.space-2;
                        Text {
                            text: "Build complete — checks skipped for now";
                            font-size: Sizes.font-md;
                            font-weight: 700;
                            color: Palette.text;
                        }
                        Text {
                            text: "You can stop here, ship the ISO, or come back later to run checksum and ISO layout checks.";
                            font-size: Sizes.font-sm;
                            color: Palette.muted;
                            wrap: word-wrap;
                        }
                    }
                }
                if verify-done: ResultCard {
                    has-result: true;
                    passed: verify-matched;
                    result-title: verify-matched ? "Integrity verified" : "Checksum mismatch";
                    detail: verify-hash-display;
                }
                if iso9660-done: ResultCard {
                    has-result: true;
                    passed: iso9660-compliant;
                    result-title: iso9660-compliant ? "ISO-9660 compliant" : "ISO-9660 issues found";
                    detail: (iso9660-boot-bios ? "BIOS boot ✓  " : "")
                          + (iso9660-boot-uefi ? "UEFI boot ✓  " : "")
                          + (iso9660-volume-id != "" ? "Label: " + iso9660-volume-id : "");
                }
            }
        }

        // ── Danger zone (reset) ──────────────────────────────────────
        FButton {
            label: "Reset All Forms";
            icon: "🗑";
            variant: "destructive";
            enabled: !running;
            clicked => { clear-forms(); }
        }
    }
}
