import { Palette, Sizes } from "../theme.slint";

component ResultCard inherits Rectangle {
    in property <bool>   passed;
    in property <bool>   has-result;
    in property <string> title;
    in property <string> detail;
    border-radius: Sizes.radius-lg;
    background: !has-result ? Palette.surface
              : passed ? rgba(34, 197, 94, 0.05)
              : rgba(239, 68, 68, 0.05);
    border-width: 1px;
    border-color: !has-result ? Palette.border
                : passed ? rgba(34, 197, 94, 0.3)
                : rgba(239, 68, 68, 0.3);
    drop-shadow-blur: has-result ? 14px : 0px;
    drop-shadow-color: has-result
        ? (passed ? rgba(34, 197, 94, 0.1) : rgba(239, 68, 68, 0.1))
        : transparent;
    animate background { duration: 300ms; }
    animate drop-shadow-blur { duration: 300ms; }
    VerticalLayout {
        padding: 18px;
        spacing: 6px;
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: !has-result ? "○" : passed ? "✓" : "✗";
                font-size: 18px;
                color: !has-result ? Palette.subtle
                     : passed ? Palette.green
                     : Palette.red;
                vertical-alignment: center;
            }
            Text {
                text: title;
                font-size: Sizes.font-md;
                font-weight: 700;
                color: !has-result ? Palette.muted
                     : passed ? Palette.green
                     : Palette.red;
                vertical-alignment: center;
            }
        }
        if detail != "": Text {
            text: detail;
            font-size: Sizes.font-sm;
            color: Palette.muted;
            wrap: word-wrap;
        }
    }
}

export component StepCheck inherits Rectangle {
    // Source
    in-out property <string> verify-source;
    in-out property <string> sums-url;

    // Inject artifact (auto-filled)
    in property <string>  artifact-path;
    in property <string>  artifact-sha256;

    // Verify result
    in property <bool>    verify-done;
    in property <bool>    verify-matched;
    in property <string>  verify-hash-display;

    // ISO-9660 result
    in property <bool>    iso9660-done;
    in property <bool>    iso9660-compliant;
    in property <bool>    iso9660-boot-bios;
    in property <bool>    iso9660-boot-uefi;
    in property <string>  iso9660-volume-id;

    in property <bool>    running;

    callback back-clicked();
    callback browse-verify-source();
    callback run-verify();
    callback run-iso9660();
    callback copy-sha256();
    callback open-folder();
    callback clear-forms();

    background: Palette.bg;

    VerticalLayout {
        padding: 44px;
        spacing: 24px;
        alignment: start;

        // ── Title ─────────────────────────────────────────────────────────
        HorizontalLayout {
            spacing: 12px;
            alignment: space-between;
            VerticalLayout {
                spacing: 6px;
                Text {
                    text: "Optional Checks";
                    font-size: Sizes.font-2xl;
                    font-weight: 800;
                    color: Palette.text;
                    letter-spacing: -0.5px;
                }
                Text {
                    text: "Your ISO is already ready to use. Run checksum or ISO-9660 checks only if you want extra validation.";
                    font-size: Sizes.font-sm;
                    color: Palette.muted;
                }
            }
            HorizontalLayout {
                spacing: 8px;

                Rectangle {
                    width: 148px;
                    height: Sizes.btn-sm;
                    border-radius: Sizes.radius-sm;
                    background: chk-back-ta.has-hover && !running
                        ? rgba(99, 102, 241, 0.18) : rgba(99, 102, 241, 0.08);
                    border-width: 1.5px;
                    border-color: chk-back-ta.has-hover && !running
                        ? Palette.accent : rgba(99, 102, 241, 0.4);
                    animate background { duration: 120ms; }
                    animate border-color { duration: 120ms; }
                    Text {
                        text: "← Back to Build";
                        font-size: Sizes.font-xs;
                        font-weight: 600;
                        color: Palette.accent;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                    chk-back-ta := TouchArea {
                        enabled: !running;
                        mouse-cursor: running ? MouseCursor.default : MouseCursor.pointer;
                        clicked => { back-clicked(); }
                    }
                }

                Rectangle {
                    width: 78px;
                    height: 26px;
                    border-radius: 13px;
                    background: rgba(100, 116, 139, 0.1);
                    border-width: 1px;
                    border-color: Palette.border;
                    Text {
                        text: "Optional";
                        font-size: Sizes.font-2xs;
                        font-weight: 600;
                        color: Palette.muted;
                        letter-spacing: 0.5px;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        // ── Build success banner ──────────────────────────────────────────
        if artifact-path != "": Rectangle {
            border-radius: Sizes.radius-lg;
            background: rgba(34, 197, 94, 0.04);
            border-width: 1px;
            border-color: rgba(34, 197, 94, 0.25);
            drop-shadow-blur: 16px;
            drop-shadow-color: rgba(34, 197, 94, 0.06);

            VerticalLayout {
                padding: 20px;
                spacing: 12px;

                HorizontalLayout {
                    spacing: 10px;
                    alignment: start;
                    Text {
                        text: "✓";
                        font-size: 20px;
                        color: Palette.green;
                        vertical-alignment: center;
                    }
                    VerticalLayout {
                        spacing: 2px;
                        Text {
                            text: "Build complete — verification optional";
                            font-size: Sizes.font-lg;
                            font-weight: 700;
                            color: Palette.green;
                        }
                        Text {
                            text: artifact-path;
                            font-size: Sizes.font-sm;
                            color: Palette.muted;
                            overflow: elide;
                        }
                    }
                }

                if artifact-sha256 != "": Text {
                    text: "SHA-256: " + artifact-sha256;
                    font-size: Sizes.font-xs;
                    color: Palette.muted;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    Rectangle {
                        width: 160px;
                        height: Sizes.btn-md;
                        border-radius: Sizes.radius-sm;
                        background: snb-ta.has-hover && !running
                            ? @linear-gradient(135deg, #818cf8, #6366f1)
                            : @linear-gradient(135deg, #6366f1, #4f46e5);
                        drop-shadow-blur: 18px;
                        drop-shadow-color: rgba(99, 102, 241, 0.35);
                        animate background { duration: 120ms; }
                        Text {
                            text: "＋ Start New Build";
                            font-size: Sizes.font-sm;
                            font-weight: 600;
                            color: Palette.on-accent;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                        snb-ta := TouchArea {
                            enabled: !running;
                            mouse-cursor: running ? MouseCursor.default : MouseCursor.pointer;
                            clicked => { clear-forms(); }
                        }
                    }

                    Rectangle {
                        width: 140px;
                        height: Sizes.btn-md;
                        border-radius: Sizes.radius-sm;
                        background: csha-ta.has-hover
                            ? rgba(99, 102, 241, 0.18) : rgba(99, 102, 241, 0.08);
                        border-width: 1.5px;
                        border-color: csha-ta.has-hover ? Palette.accent : rgba(99, 102, 241, 0.4);
                        animate background { duration: 120ms; }
                        animate border-color { duration: 120ms; }
                        Text {
                            text: "📋 Copy SHA-256";
                            font-size: Sizes.font-xs;
                            font-weight: 600;
                            color: Palette.accent;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                        csha-ta := TouchArea {
                            mouse-cursor: MouseCursor.pointer;
                            clicked => { copy-sha256(); }
                        }
                    }

                    Rectangle {
                        width: 130px;
                        height: Sizes.btn-md;
                        border-radius: Sizes.radius-sm;
                        background: ofld2-ta.has-hover
                            ? rgba(99, 102, 241, 0.18) : rgba(99, 102, 241, 0.08);
                        border-width: 1.5px;
                        border-color: ofld2-ta.has-hover ? Palette.accent : rgba(99, 102, 241, 0.4);
                        animate background { duration: 120ms; }
                        animate border-color { duration: 120ms; }
                        Text {
                            text: "📂 Open Folder";
                            font-size: Sizes.font-xs;
                            font-weight: 600;
                            color: Palette.accent;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                        ofld2-ta := TouchArea {
                            mouse-cursor: MouseCursor.pointer;
                            clicked => { open-folder(); }
                        }
                    }
                }
            }
        }

        // ── Checksum Verification ─────────────────────────────────────────
        Rectangle {
            border-radius: Sizes.radius-lg;
            background: Palette.surface;
            border-width: 1px;
            border-color: Palette.border;
            clip: true;

            VerticalLayout {
                // Gradient accent line
                Rectangle {
                    height: 2px;
                    background: @linear-gradient(90deg,
                        rgba(99, 102, 241, 0.6), rgba(99, 102, 241, 0.1), transparent);
                }

                VerticalLayout {
                    padding: 20px;
                    spacing: 16px;

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: "CHECKSUM VERIFICATION";
                            font-size: Sizes.font-xs;
                            font-weight: 700;
                            color: Palette.muted;
                            letter-spacing: 1.2px;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            width: 68px;
                            height: 20px;
                            border-radius: 10px;
                            background: rgba(100, 116, 139, 0.08);
                            border-width: 1px;
                            border-color: Palette.border;
                            Text {
                                text: "Optional";
                                font-size: Sizes.font-2xs;
                                color: Palette.muted;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            height: Sizes.btn-lg;
                            border-radius: Sizes.radius-md;
                            background: Palette.input;
                            border-width: 1.5px;
                            border-color: vsrc-input.has-focus ? Palette.accent : Palette.border;
                            drop-shadow-blur: vsrc-input.has-focus ? 14px : 0px;
                            drop-shadow-color: vsrc-input.has-focus
                                ? rgba(99, 102, 241, 0.15) : transparent;
                            animate border-color { duration: 180ms; }
                            animate drop-shadow-blur { duration: 250ms; }
                            if verify-source == "" && !vsrc-input.has-focus: Text {
                                x: 14px; y: 0;
                                width: parent.width - 28px;
                                height: parent.height;
                                text: "/path/to/output.iso  or  https://…";
                                font-size: Sizes.font-sm;
                                color: Palette.subtle;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            vsrc-input := TextInput {
                                x: 14px;
                                y: (parent.height - self.preferred-height) / 2;
                                width: parent.width - 28px;
                                text: verify-source;
                                font-size: Sizes.font-sm;
                                color: Palette.text;
                                selection-background-color: Palette.accent;
                                selection-foreground-color: Palette.on-accent;
                                single-line: true;
                                enabled: !running;
                                edited => { verify-source = self.text; }
                            }
                        }
                        Rectangle {
                            width: 100px;
                            height: Sizes.btn-lg;
                            border-radius: Sizes.radius-md;
                            background: vbrw-ta.has-hover && !running
                                ? rgba(99, 102, 241, 0.18) : rgba(99, 102, 241, 0.08);
                            border-width: 1.5px;
                            border-color: vbrw-ta.has-hover && !running
                                ? Palette.accent : rgba(99, 102, 241, 0.4);
                            animate background { duration: 120ms; }
                            animate border-color { duration: 120ms; }
                            Text {
                                text: "Browse…";
                                font-size: Sizes.font-sm;
                                font-weight: 600;
                                color: Palette.accent;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                            vbrw-ta := TouchArea {
                                enabled: !running;
                                mouse-cursor: running ? MouseCursor.default : MouseCursor.pointer;
                                clicked => { browse-verify-source(); }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            height: Sizes.btn-lg;
                            border-radius: Sizes.radius-md;
                            background: Palette.input;
                            border-width: 1.5px;
                            border-color: sums-input.has-focus ? Palette.accent : Palette.border;
                            drop-shadow-blur: sums-input.has-focus ? 14px : 0px;
                            drop-shadow-color: sums-input.has-focus
                                ? rgba(99, 102, 241, 0.15) : transparent;
                            animate border-color { duration: 180ms; }
                            animate drop-shadow-blur { duration: 250ms; }
                            if sums-url == "" && !sums-input.has-focus: Text {
                                x: 14px; y: 0;
                                width: parent.width - 28px;
                                height: parent.height;
                                text: "SHA256SUMS URL or file path (optional)";
                                font-size: Sizes.font-sm;
                                color: Palette.subtle;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            sums-input := TextInput {
                                x: 14px;
                                y: (parent.height - self.preferred-height) / 2;
                                width: parent.width - 28px;
                                text: sums-url;
                                font-size: Sizes.font-sm;
                                color: Palette.text;
                                selection-background-color: Palette.accent;
                                selection-foreground-color: Palette.on-accent;
                                single-line: true;
                                enabled: !running;
                                edited => { sums-url = self.text; }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 12px;
                        alignment: start;
                        Rectangle {
                            property <bool> ck-active: verify-source != "" && !running;
                            width: 176px;
                            height: Sizes.btn-md;
                            border-radius: Sizes.radius-sm;
                            background: ck-active
                                ? (cfi-ta.has-hover
                                    ? @linear-gradient(135deg, #818cf8, #6366f1)
                                    : @linear-gradient(135deg, #6366f1, #4f46e5))
                                : Palette.elevated;
                            opacity: ck-active ? 1.0 : 0.4;
                            drop-shadow-blur: ck-active ? 14px : 0px;
                            drop-shadow-color: ck-active
                                ? rgba(99, 102, 241, 0.2) : transparent;
                            animate background { duration: 150ms; }
                            animate drop-shadow-blur { duration: 250ms; }
                            Text {
                                text: "🔍 Check Integrity";
                                font-size: Sizes.font-sm;
                                font-weight: 600;
                                color: ck-active ? Palette.on-accent : Palette.subtle;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                            cfi-ta := TouchArea {
                                enabled: ck-active;
                                mouse-cursor: ck-active ? MouseCursor.pointer : MouseCursor.default;
                                clicked => { run-verify(); }
                            }
                        }
                        Rectangle {
                            property <bool> iso-active: verify-source != "" && !running;
                            width: 168px;
                            height: Sizes.btn-md;
                            border-radius: Sizes.radius-sm;
                            background: iso-ta.has-hover && iso-active
                                ? rgba(99, 102, 241, 0.18) : rgba(99, 102, 241, 0.08);
                            border-width: 1.5px;
                            border-color: iso-active
                                ? (iso-ta.has-hover ? Palette.accent : rgba(99, 102, 241, 0.4))
                                : Palette.border;
                            opacity: iso-active ? 1.0 : 0.4;
                            animate background { duration: 120ms; }
                            animate border-color { duration: 120ms; }
                            Text {
                                text: "📋 ISO-9660 Layout";
                                font-size: Sizes.font-sm;
                                font-weight: 600;
                                color: iso-active ? Palette.accent : Palette.subtle;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                            iso-ta := TouchArea {
                                enabled: iso-active;
                                mouse-cursor: iso-active ? MouseCursor.pointer : MouseCursor.default;
                                clicked => { run-iso9660(); }
                            }
                        }
                    }

                    // Results
                    if !verify-done && !iso9660-done: Rectangle {
                        border-radius: Sizes.radius-md;
                        background: Palette.elevated;
                        border-width: 1px;
                        border-color: Palette.border;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 4px;
                            Text {
                                text: "No checks run yet";
                                font-size: Sizes.font-md;
                                font-weight: 700;
                                color: Palette.text;
                            }
                            Text {
                                text: "You can skip this entirely, or run checksum and ISO layout checks above.";
                                font-size: Sizes.font-sm;
                                color: Palette.muted;
                                wrap: word-wrap;
                            }
                        }
                    }
                    if verify-done: ResultCard {
                        has-result: true;
                        passed: verify-matched;
                        title: verify-matched ? "Integrity verified" : "Checksum mismatch";
                        detail: verify-hash-display;
                    }
                    if iso9660-done: ResultCard {
                        has-result: true;
                        passed: iso9660-compliant;
                        title: iso9660-compliant ? "ISO-9660 compliant" : "ISO-9660 issues found";
                        detail: (iso9660-boot-bios ? "BIOS boot ✓  " : "")
                              + (iso9660-boot-uefi ? "UEFI boot ✓  " : "")
                              + (iso9660-volume-id != "" ? "Label: " + iso9660-volume-id : "");
                    }
                }
            }
        }

        // ── Danger zone (reset) ───────────────────────────────────────────
        Rectangle {
            width: 156px;
            height: Sizes.btn-sm;
            border-radius: Sizes.radius-sm;
            background: rst-ta.has-hover && !running ? rgba(239, 68, 68, 0.08) : Palette.elevated;
            animate background { duration: 120ms; }
            border-width: 1px;
            border-color: rst-ta.has-hover && !running ? rgba(239, 68, 68, 0.25) : Palette.border;
            animate border-color { duration: 120ms; }
            Text {
                text: "🗑 Reset All Forms";
                font-size: Sizes.font-xs;
                color: rst-ta.has-hover && !running ? Palette.red : Palette.muted;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
            rst-ta := TouchArea {
                enabled: !running;
                mouse-cursor: running ? MouseCursor.default : MouseCursor.pointer;
                clicked => { clear-forms(); }
            }
        }
    }
}
