import { Palette, Sizes } from "../theme.slint";
import { ScrollView } from "std-widgets.slint";
import { FButton, FCard, FBadge, FDivider } from "../components/design_system.slint";

component CollapsibleCard inherits Rectangle {
    in property <string> title;
    in-out property <bool> expanded: false;

    border-radius: Sizes.radius-lg;
    background: Palette.surface;
    border-width: 1px;
    border-color: Palette.border;
    drop-shadow-blur: 4px;
    drop-shadow-color: Palette.shadow-sm;
    clip: true;

    VerticalLayout {
        // Title bar — always visible, clickable
        Rectangle {
            height: 40px;
            HorizontalLayout {
                padding-left: Sizes.space-5;
                padding-right: Sizes.space-5;
                alignment: space-between;
                Text {
                    text: title;
                    font-size: Sizes.font-2xs;
                    font-weight: 700;
                    color: Palette.subtle;
                    letter-spacing: 1.4px;
                    vertical-alignment: center;
                }
                Text {
                    text: expanded ? "\u{25B2}" : "\u{25BC}";
                    font-size: Sizes.font-2xs;
                    color: cc-ta.has-hover ? Palette.text-secondary : Palette.subtle;
                    vertical-alignment: center;
                    animate color { duration: 120ms; }
                }
            }
            cc-ta := TouchArea {
                mouse-cursor: MouseCursor.pointer;
                clicked => { expanded = !expanded; }
            }
        }
        Rectangle {
            height: expanded ? 1px : 0px;
            background: Palette.border;
            opacity: 0.5;
        }
        // Content area — height collapses when not expanded
        Rectangle {
            height: expanded ? content-layout.preferred-height : 0px;
            animate height { duration: 200ms; easing: ease-out; }
            content-layout := VerticalLayout {
                @children
            }
        }
    }
}

component SummaryRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <bool>   set: true;

    height: value-text.preferred-height + Sizes.space-6;
    background: transparent;

    VerticalLayout {
        spacing: Sizes.space-1;
        Text {
            text: label;
            font-size: Sizes.font-2xs;
            font-weight: 700;
            color: Palette.subtle;
            letter-spacing: 1.2px;
        }
        value-text := Text {
            text: set ? value : "— not set";
            font-size: Sizes.font-sm;
            color: set ? Palette.text : Palette.subtle;
            font-weight: set ? 600 : 400;
            wrap: word-wrap;
        }
    }
}

export component StepBuild inherits Rectangle {
    in property <string>  distro-display;
    in property <string>  admin-group;
    in property <string>  source;
    in property <string>  expected-sha256;
    in property <string>  hostname;
    in property <string>  username;
    in property <string>  realname;
    in property <bool>    password-set;
    in property <string>  user-groups;
    in property <string>  user-shell;
    in property <bool>    sudo-nopasswd;
    in property <bool>    ssh-server;
    in property <bool>    ssh-password-auth;
    in property <string>  ssh-keys;
    in property <string>  timezone;
    in property <string>  locale;
    in property <string>  keyboard-layout;
    in property <string>  static-ip;
    in property <string>  gateway;
    in property <string>  dns-servers;
    in property <string>  ntp-servers;
    in property <bool>    firewall-on;
    in property <string>  firewall-policy;
    in property <string>  allow-ports;
    in property <string>  deny-ports;
    in property <string>  output-dir;
    in property <string>  out-name;
    in property <string>  output-label;
    in property <bool>    unattended;
    in property <bool>    running;
    in property <string>  packages;
    in property <string>  extra-repos;
    in property <string>  enable-services;
    in property <string>  disable-services;
    in property <bool>    docker-on;
    in property <bool>    podman-on;
    in property <string>  docker-users;
    in property <bool>    encrypt-on;
    in property <string>  storage-layout;
    in property <string>  mounts;
    in property <string>  run-commands;
    in property <string>  late-commands;
    in property <string>  artifact-path;
    in property <string>  artifact-sha256;
    in property <string>  verify-summary;

    callback back-clicked();
    callback back-to-source();
    callback run-clicked();
    callback view-results();
    callback open-folder();
    callback start-over();

    background: Palette.bg;

    ScrollView {
        VerticalLayout {
            padding: Sizes.space-10;
            spacing: Sizes.space-5;
            alignment: start;

            // ── Header ──────────────────────────────────────────────────
            HorizontalLayout {
                alignment: space-between;
                VerticalLayout {
                    spacing: Sizes.space-1;
                    Text {
                        text: artifact-path == "" ? "Review & Build" : "ISO Ready";
                        font-size: Sizes.font-2xl;
                        font-weight: 700;
                        color: Palette.text;
                    }
                    Text {
                        text: artifact-path == ""
                            ? "Inspect the full plan below. Nothing starts until you click Start Build."
                            : "Build is complete. Optional checks are available if you want an extra confidence pass.";
                        font-size: Sizes.font-sm;
                        color: Palette.muted;
                    }
                }
                if artifact-path == "": HorizontalLayout {
                    spacing: Sizes.space-2;
                    alignment: end;
                    FButton {
                        label: "← Choose ISO";
                        variant: "secondary";
                        enabled: !running;
                        clicked => { back-to-source(); }
                    }
                    FButton {
                        label: "← Edit Settings";
                        variant: "secondary";
                        enabled: !running;
                        clicked => { back-clicked(); }
                    }
                }
            }

            // ── Confirmation banner ─────────────────────────────────────
            if artifact-path == "": FCard {
                border-color: rgba(77, 142, 247, 0.25);
                background: rgba(77, 142, 247, 0.06);
                drop-shadow-blur: 0px;

                VerticalLayout {
                    padding: Sizes.space-4;
                    spacing: Sizes.space-2;
                    Text {
                        text: "CONFIRMATION STAGE";
                        font-size: Sizes.font-2xs;
                        font-weight: 700;
                        color: Palette.accent;
                        letter-spacing: 1.4px;
                    }
                    Text {
                        text: "Use the back buttons if anything looks wrong. Build starts only when you click Start Build below.";
                        font-size: Sizes.font-sm;
                        color: Palette.text-secondary;
                        wrap: word-wrap;
                    }
                }
            }

            // ── Source & Output ──────────────────────────────────────────
            if artifact-path == "": CollapsibleCard {
                title: "SOURCE & OUTPUT";
                expanded: true;
                VerticalLayout {
                    padding: Sizes.space-5;
                    spacing: Sizes.space-3;
                    SummaryRow { label: "INSTALLER FORMAT"; value: distro-display; }
                    SummaryRow { label: "SOURCE ISO"; value: source; }
                    if expected-sha256 != "": SummaryRow { label: "EXPECTED SOURCE SHA-256"; value: expected-sha256; }
                    SummaryRow { label: "OUTPUT DIRECTORY"; value: output-dir; }
                    SummaryRow { label: "OUTPUT FILENAME"; value: out-name; }
                    if output-label != "": SummaryRow { label: "VOLUME LABEL"; value: output-label; }
                }
            }

            // ── Identity & Access ───────────────────────────────────────
            if artifact-path == "": CollapsibleCard {
                title: "IDENTITY & ACCESS";
                VerticalLayout {
                    padding: Sizes.space-5;
                    spacing: Sizes.space-3;
                    SummaryRow { label: "HOSTNAME"; value: hostname; set: hostname != ""; }
                    SummaryRow { label: "USERNAME"; value: username; set: username != ""; }
                    if realname != "": SummaryRow { label: "FULL NAME"; value: realname; }
                    SummaryRow { label: "PASSWORD"; value: password-set ? "Configured" : "Not set"; set: password-set; }
                    SummaryRow {
                        label: "ADMIN ACCESS";
                        value: sudo-nopasswd ? admin-group + " + passwordless sudo" : admin-group;
                        set: admin-group != "";
                    }
                    if user-groups != "": SummaryRow { label: "GROUPS"; value: user-groups; }
                    if user-shell != "": SummaryRow { label: "LOGIN SHELL"; value: user-shell; }
                    FDivider {}
                    SummaryRow { label: "SSH SERVER"; value: ssh-server ? "Install and enable" : "Not requested"; set: true; }
                    SummaryRow {
                        label: "SSH PASSWORD AUTH";
                        value: ssh-password-auth ? "Allowed" : "Disabled";
                        set: ssh-server;
                    }
                    SummaryRow {
                        label: "SSH KEYS";
                        value: ssh-keys != "" ? "Configured" : "None provided";
                        set: true;
                    }
                }
            }

            // ── System, Network & Security ──────────────────────────────
            if artifact-path == "": CollapsibleCard {
                title: "SYSTEM, NETWORK & SECURITY";
                VerticalLayout {
                    padding: Sizes.space-5;
                    spacing: Sizes.space-3;
                    if timezone != "": SummaryRow { label: "TIMEZONE"; value: timezone; }
                    if locale != "": SummaryRow { label: "LOCALE"; value: locale; }
                    if keyboard-layout != "": SummaryRow { label: "KEYBOARD LAYOUT"; value: keyboard-layout; }
                    if storage-layout != "": SummaryRow { label: "STORAGE LAYOUT"; value: storage-layout; }
                    FDivider {}
                    SummaryRow { label: "IP CONFIGURATION"; value: static-ip != "" ? static-ip : "DHCP"; set: true; }
                    if gateway != "": SummaryRow { label: "GATEWAY"; value: gateway; }
                    if dns-servers != "": SummaryRow { label: "DNS SERVERS"; value: dns-servers; }
                    if ntp-servers != "": SummaryRow { label: "NTP SERVERS"; value: ntp-servers; }
                    FDivider {}
                    SummaryRow {
                        label: "FIREWALL";
                        value: firewall-on
                            ? (firewall-policy != ""
                                ? "Enabled (" + firewall-policy + ")"
                                : "Enabled")
                            : "Disabled";
                        set: true;
                    }
                    if allow-ports != "": SummaryRow { label: "ALLOWED PORTS"; value: allow-ports; }
                    if deny-ports != "": SummaryRow { label: "DENIED PORTS"; value: deny-ports; }
                    if encrypt-on: SummaryRow { label: "DISK ENCRYPTION"; value: "LUKS enabled"; }
                }
            }

            // ── Packages, Services & Runtime ────────────────────────────
            if artifact-path == "" && (packages != "" || extra-repos != "" || enable-services != "" || disable-services != "" || docker-on || podman-on || mounts != ""): CollapsibleCard {
                title: "PACKAGES, SERVICES & RUNTIME";
                VerticalLayout {
                    padding: Sizes.space-5;
                    spacing: Sizes.space-3;
                    if packages != "": SummaryRow { label: "EXTRA PACKAGES"; value: packages; }
                    if extra-repos != "": SummaryRow { label: "EXTRA REPOSITORIES"; value: extra-repos; }
                    if enable-services != "": SummaryRow { label: "ENABLE SERVICES"; value: enable-services; }
                    if disable-services != "": SummaryRow { label: "DISABLE SERVICES"; value: disable-services; }
                    if docker-on || podman-on: SummaryRow {
                        label: "CONTAINERS";
                        value: docker-on && podman-on ? "Docker + Podman"
                             : docker-on ? "Docker"
                             : "Podman";
                    }
                    if docker-users != "": SummaryRow { label: "DOCKER USERS"; value: docker-users; }
                    if mounts != "": SummaryRow { label: "CUSTOM MOUNTS"; value: mounts; }
                }
            }

            // ── Custom Behavior ─────────────────────────────────────────
            if artifact-path == "" && (run-commands != "" || late-commands != "" || unattended): CollapsibleCard {
                title: "CUSTOM BEHAVIOR";
                VerticalLayout {
                    padding: Sizes.space-5;
                    spacing: Sizes.space-3;
                    if run-commands != "": SummaryRow { label: "RUN COMMANDS"; value: run-commands; }
                    if late-commands != "": SummaryRow { label: "LATE COMMANDS"; value: late-commands; }
                    if unattended: SummaryRow {
                        label: "INSTALLER MODE";
                        value: "Fully unattended — target disks will be wiped without prompts";
                    }
                }
            }

            // ── Unattended warning banner ───────────────────────────────
            if unattended && artifact-path == "": FCard {
                border-color: rgba(227, 166, 44, 0.35);
                background: rgba(227, 166, 44, 0.06);
                drop-shadow-blur: 0px;

                VerticalLayout {
                    padding: Sizes.space-4;
                    spacing: Sizes.space-2;
                    HorizontalLayout {
                        spacing: Sizes.space-2;
                        alignment: start;
                        FBadge {
                            text: "UNATTENDED";
                            variant: "warning";
                        }
                    }
                    Text {
                        text: "This build will create media that installs without interactive prompts. Review the plan above carefully before you continue.";
                        font-size: Sizes.font-sm;
                        color: Palette.amber;
                        wrap: word-wrap;
                    }
                }
            }

            // ── Start Build button ──────────────────────────────────────
            if artifact-path == "": HorizontalLayout {
                spacing: Sizes.space-4;
                alignment: start;

                FButton {
                    height: 50px;
                    min-width: 220px;
                    label: running ? "Building…" : "Start Build";
                    icon: running ? "" : "🔨";
                    variant: running ? "secondary" : "primary";
                    enabled: !running;
                    clicked => { run-clicked(); }
                }
            }

            // ── Rebuild section (post-build) ────────────────────────────
            if artifact-path != "": VerticalLayout {
                spacing: Sizes.space-2;
                Text {
                    text: "Need another artifact after changing settings?";
                    font-size: Sizes.font-sm;
                    color: Palette.muted;
                }
                FButton {
                    label: "Rebuild ISO";
                    variant: "secondary";
                    enabled: !running;
                    clicked => { run-clicked(); }
                }
            }

            // ── Success banner (post-build) ─────────────────────────────
            if artifact-path != "": FCard {
                border-color: rgba(69, 194, 107, 0.35);
                background: rgba(69, 194, 107, 0.05);

                VerticalLayout {
                    padding: Sizes.space-5;
                    spacing: Sizes.space-3;
                    HorizontalLayout {
                        spacing: Sizes.space-2;
                        Text {
                            text: "✓";
                            font-size: 18px;
                            color: Palette.green;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "Build complete";
                            font-size: Sizes.font-lg;
                            font-weight: 700;
                            color: Palette.green;
                            vertical-alignment: center;
                        }
                    }
                    Text {
                        text: artifact-path;
                        font-size: Sizes.font-sm;
                        color: Palette.muted;
                        overflow: elide;
                    }
                    if artifact-sha256 != "": Text {
                        text: "SHA-256: " + artifact-sha256;
                        font-size: Sizes.font-xs;
                        font-family: "monospace";
                        color: Palette.subtle;
                    }
                    if verify-summary != "": Text {
                        text: verify-summary;
                        font-size: Sizes.font-sm;
                        color: Palette.muted;
                    }
                    FDivider {}
                    HorizontalLayout {
                        spacing: Sizes.space-3;
                        alignment: start;

                        FButton {
                            label: "Optional Checks →";
                            variant: "primary";
                            clicked => { view-results(); }
                        }

                        FButton {
                            label: "Open Folder";
                            variant: "secondary";
                            clicked => { open-folder(); }
                        }

                        FButton {
                            label: "Start New Build";
                            variant: "secondary";
                            clicked => { start-over(); }
                        }
                    }
                }
            }
        }
    }
}
