import { Palette, Sizes } from "../theme.slint";
import { ScrollView, CheckBox } from "std-widgets.slint";

// ── Reusable field components ────────────────────────────────────────────────

component FieldLabel inherits Text {
    font-size: Sizes.font-xs;
    font-weight: 600;
    color: Palette.text-secondary;
    letter-spacing: 0.5px;
}

component FieldHelp inherits Text {
    font-size: Sizes.font-xs;
    color: Palette.subtle;
    wrap: word-wrap;
}

component FieldInput inherits Rectangle {
    in-out property <string> value;
    in property <string>     hint: "";
    in property <bool>       password: false;
    in property <bool>       enabled: true;
    in property <bool>       error: false;
    callback changed(string);

    height: Sizes.btn-md;
    border-radius: Sizes.radius-sm;
    background: Palette.input;
    border-width: 1.5px;
    border-color: error ? Palette.red
                : field.has-focus ? Palette.border-focus
                : Palette.border;
    drop-shadow-blur: error ? 12px
                    : field.has-focus ? 12px
                    : 0px;
    drop-shadow-color: error ? rgba(239, 68, 68, 0.15)
                     : field.has-focus ? rgba(99, 102, 241, 0.15)
                     : transparent;
    animate border-color { duration: 180ms; }
    animate drop-shadow-blur { duration: 220ms; }
    animate drop-shadow-color { duration: 220ms; }

    if value == "" && !field.has-focus: Text {
        x: 14px;
        y: 0;
        width: parent.width - 28px;
        height: parent.height;
        text: hint;
        font-size: Sizes.font-sm;
        color: Palette.subtle;
        vertical-alignment: center;
    }
    field := TextInput {
        x: 14px;
        y: (parent.height - self.preferred-height) / 2;
        width: parent.width - 28px;
        text: value;
        font-size: Sizes.font-sm;
        color: Palette.text;
        selection-background-color: Palette.accent;
        selection-foreground-color: Palette.on-accent;
        enabled: parent.enabled;
        single-line: true;
        input-type: password ? InputType.password : InputType.text;
        edited => { value = field.text; changed(field.text); }
    }
}

component FieldTextarea inherits Rectangle {
    in-out property <string> value;
    in property <string>     hint: "";
    in property <bool>       enabled: true;
    callback changed(string);

    height: 104px;
    border-radius: Sizes.radius-sm;
    background: Palette.input;
    border-width: 1.5px;
    border-color: editor.has-focus ? Palette.border-focus : Palette.border;
    drop-shadow-blur: editor.has-focus ? 12px : 0px;
    drop-shadow-color: editor.has-focus ? rgba(99, 102, 241, 0.15) : transparent;
    animate border-color { duration: 180ms; }
    animate drop-shadow-blur { duration: 220ms; }

    editor := TextInput {
        x: 14px;
        y: 10px;
        width: parent.width - 28px;
        height: parent.height - 20px;
        text: value;
        font-size: Sizes.font-sm;
        color: Palette.text;
        selection-background-color: Palette.accent;
        selection-foreground-color: Palette.on-accent;
        enabled: parent.enabled;
        single-line: false;
        wrap: word-wrap;
        edited => { value = editor.text; changed(editor.text); }
    }
}

component SectionHeader inherits Rectangle {
    in property <string> title;
    in property <bool>   open: true;
    callback toggle();

    height: 48px;
    background: hov.has-hover ? rgba(255, 255, 255, 0.025) : transparent;
    animate background { duration: 120ms; }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 12px;
        alignment: space-between;

        HorizontalLayout {
            spacing: 12px;
            alignment: start;
            Rectangle {
                width: 3px;
                height: 20px;
                border-radius: 1.5px;
                background: open
                    ? @linear-gradient(180deg, #6366f1, #818cf8)
                    : Palette.border;
                y: (parent.height - self.height) / 2;
                animate background { duration: 200ms; }
            }
            Text {
                text: title;
                font-size: Sizes.font-sm;
                font-weight: 700;
                color: open ? Palette.text : Palette.text-secondary;
                vertical-alignment: center;
                animate color { duration: 150ms; }
            }
        }

        Rectangle {
            width: 28px;
            height: 28px;
            border-radius: 14px;
            background: hov.has-hover ? Palette.active : transparent;
            animate background { duration: 100ms; }
            Text {
                text: open ? "▾" : "▸";
                font-size: Sizes.font-sm;
                color: open ? Palette.accent : Palette.subtle;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }
    }

    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: Palette.border;
        opacity: 0.4;
    }

    hov := TouchArea {
        mouse-cursor: MouseCursor.pointer;
        clicked => { toggle(); }
    }
}

component CollapsedSummary inherits Rectangle {
    in property <string> summary;

    height: 34px;
    background: rgba(99, 102, 241, 0.06);
    border-radius: Sizes.radius-sm;
    border-width: 1px;
    border-color: rgba(99, 102, 241, 0.18);

    HorizontalLayout {
        padding-left: 24px;
        padding-right: 14px;
        alignment: start;
        Text {
            text: summary;
            font-size: Sizes.font-xs;
            color: Palette.text-secondary;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

// ── Main configure step ──────────────────────────────────────────────────────

export component StepConfigure inherits Rectangle {
    in property <string>  source-display;
    in property <string>  distro;
    in property <string>  selected-preset-name;
    in property <string>  distro-display;
    callback distro-changed(string);
    callback clear-source();

    in-out property <string> hostname;
    in-out property <string> username;
    in-out property <string> password;
    in-out property <string> password-confirm;
    in-out property <string> realname;
    in property <bool>       passwords-match: true;
    property <bool> pw-live-mismatch: password != "" && password-confirm != ""
                                       && password != password-confirm;

    in-out property <string> ssh-keys;
    in-out property <bool>   ssh-password-auth: false;
    in-out property <bool>   ssh-install-server: true;
    in-out property <string> dns-servers;
    in-out property <string> ntp-servers;
    in-out property <string> static-ip;
    in-out property <string> gateway;
    in-out property <string> http-proxy;
    in-out property <string> https-proxy;
    in-out property <string> no-proxy;
    in-out property <string> timezone;
    in-out property <string> locale;
    in-out property <string> keyboard-layout;
    in-out property <string> storage-layout;
    in-out property <string> apt-mirror;
    in-out property <string> packages;
    in-out property <string> apt-repos;
    in-out property <string> dnf-repos;
    in-out property <string> run-commands;
    in-out property <string> late-commands;
    in-out property <bool>   firewall-enabled: false;
    in-out property <string> firewall-policy;
    in-out property <string> allow-ports;
    in-out property <string> deny-ports;
    in-out property <string> user-groups;
    in-out property <string> user-shell;
    in-out property <bool>   sudo-nopasswd: false;
    in-out property <string> enable-services;
    in-out property <string> disable-services;
    in-out property <bool>   docker: false;
    in-out property <bool>   podman: false;
    in-out property <string> docker-users;
    in-out property <string> swap-size-mb;
    in-out property <bool>   encrypt: false;
    in-out property <string> encrypt-passphrase;
    in-out property <string> mounts;
    in-out property <string> grub-timeout;
    in-out property <string> grub-cmdline;
    in-out property <string> sysctl-pairs;
    in-out property <string> output-dir;
    in-out property <string> out-name;
    in-out property <string> output-label;
    in-out property <string> expected-sha256;
    in-out property <bool>   no-user-interaction: false;

    in-out property <bool> s-identity-open: true;
    in-out property <bool> s-access-ssh-open: false;
    in-out property <bool> s-network-open: false;
    in-out property <bool> s-system-open: false;
    in-out property <bool> s-packages-open: false;
    in-out property <bool> s-advanced-open: false;
    in-out property <bool> s-firewall-open: false;
    in-out property <bool> s-services-containers-open: false;
    in-out property <bool> s-storage-boot-open: false;
    in-out property <bool> s-output-open: true;

    in property <string>  defaults-summary;
    callback apply-defaults();
    callback reset-defaults();
    callback field-edited(string);
    callback username-changed(string);
    callback docker-changed();
    in property <bool>    running: false;
    in property <bool>    can-continue: false;
    callback browse-output-dir();
    callback configure-continue();
    callback back-clicked();

    background: Palette.bg;

    HorizontalLayout {
        ScrollView {
            VerticalLayout {
                padding-left: 48px;
                padding-right: 48px;
                padding-top: 36px;
                padding-bottom: 48px;
                spacing: 18px;
                alignment: start;

                // Title row
                HorizontalLayout {
                    spacing: 12px;
                    alignment: space-between;
                    VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: "Configure Installer";
                            font-size: Sizes.font-2xl;
                            font-weight: 800;
                            color: Palette.text;
                            letter-spacing: -0.5px;
                        }
                        Text {
                            text: "Start with identity and output. The rest is optional.";
                            font-size: Sizes.font-sm;
                            color: Palette.muted;
                        }
                    }
                    Rectangle {
                        width: 130px;
                        height: Sizes.btn-sm;
                        border-radius: Sizes.radius-sm;
                        background: cfg-back-ta.has-hover
                            ? rgba(99, 102, 241, 0.18) : rgba(99, 102, 241, 0.08);
                        border-width: 1.5px;
                        border-color: cfg-back-ta.has-hover
                            ? Palette.accent : rgba(99, 102, 241, 0.4);
                        animate background { duration: 120ms; }
                        animate border-color { duration: 120ms; }
                        Text {
                            text: "← Change ISO";
                            font-size: Sizes.font-sm;
                            font-weight: 600;
                            color: Palette.accent;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                        cfg-back-ta := TouchArea {
                            mouse-cursor: MouseCursor.pointer;
                            clicked => { back-clicked(); }
                        }
                    }
                }

                // Source display
                Rectangle {
                    height: selected-preset-name != "" ? 62px : 46px;
                    border-radius: Sizes.radius-md;
                    background: rgba(99, 102, 241, 0.06);
                    border-width: 1px;
                    border-color: rgba(99, 102, 241, 0.2);
                    VerticalLayout {
                        padding-left: 18px;
                        padding-right: 18px;
                        padding-top: 10px;
                        padding-bottom: 10px;
                        spacing: 4px;
                        alignment: start;
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            Text { text: "📀"; font-size: 16px; vertical-alignment: center; }
                            Text {
                                text: source-display;
                                font-size: Sizes.font-sm;
                                color: Palette.text;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                        if selected-preset-name != "": Text {
                            text: "Preset: " + selected-preset-name + "  ·  " + distro-display;
                            font-size: Sizes.font-xs;
                            color: Palette.muted;
                            overflow: elide;
                        }
                    }
                }

                // Defaults banner
                if defaults-summary != "": Rectangle {
                    height: 44px;
                    border-radius: Sizes.radius-sm;
                    background: rgba(34, 197, 94, 0.05);
                    border-width: 1px;
                    border-color: rgba(34, 197, 94, 0.18);
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 10px;
                        spacing: 10px;
                        alignment: space-between;
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            Text { text: "⚙"; font-size: 14px; vertical-alignment: center; }
                            Text {
                                text: "Defaults: " + defaults-summary;
                                font-size: Sizes.font-xs;
                                color: Palette.muted;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: end;
                            Rectangle {
                                width: 120px;
                                height: 30px;
                                border-radius: Sizes.radius-sm;
                                background: apply-ta.has-hover && !running
                                    ? rgba(34, 197, 94, 0.16)
                                    : rgba(34, 197, 94, 0.07);
                                border-width: 1px;
                                border-color: rgba(34, 197, 94, 0.25);
                                animate background { duration: 100ms; }
                                Text {
                                    text: "Apply Defaults";
                                    font-size: Sizes.font-xs;
                                    font-weight: 600;
                                    color: Palette.green;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                }
                                apply-ta := TouchArea {
                                    enabled: !running;
                                    mouse-cursor: running ? MouseCursor.default : MouseCursor.pointer;
                                    clicked => { apply-defaults(); }
                                }
                            }
                            Rectangle {
                                width: 68px;
                                height: 30px;
                                border-radius: Sizes.radius-sm;
                                background: reset-ta.has-hover && !running ? Palette.active : Palette.elevated;
                                border-width: 1px;
                                border-color: Palette.border;
                                animate background { duration: 100ms; }
                                Text {
                                    text: "Reset";
                                    font-size: Sizes.font-xs;
                                    color: Palette.muted;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                }
                                reset-ta := TouchArea {
                                    enabled: !running;
                                    mouse-cursor: running ? MouseCursor.default : MouseCursor.pointer;
                                    clicked => { reset-defaults(); }
                                }
                            }
                        }
                    }
                }

                // ── IDENTITY ──────────────────────────────────────────────
                SectionHeader { title: "Identity (required)"; open: s-identity-open; toggle => { s-identity-open = !s-identity-open; } }
                if s-identity-open: VerticalLayout {
                    spacing: 12px;
                    HorizontalLayout {
                        spacing: 16px;
                        VerticalLayout { spacing: 4px; FieldLabel { text: "HOSTNAME"; } FieldInput { value <=> hostname; hint: "myserver"; enabled: !running; } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "USERNAME"; } FieldInput { value <=> username; hint: "admin"; enabled: !running; changed(t) => { username-changed(t); } } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "FULL NAME"; } FieldInput { value <=> realname; hint: "Admin User"; enabled: !running; } }
                    }
                    HorizontalLayout {
                        spacing: 16px;
                        VerticalLayout { spacing: 4px; FieldLabel { text: "PASSWORD"; } FieldInput { value <=> password; password: true; hint: "••••••••"; enabled: !running; } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "CONFIRM PASSWORD"; } FieldInput { value <=> password-confirm; password: true; hint: "••••••••"; enabled: !running; error: pw-live-mismatch; } }
                    }
                    if !passwords-match || pw-live-mismatch: Rectangle {
                        height: 32px; border-radius: Sizes.radius-sm;
                        background: rgba(239, 68, 68, 0.08); border-width: 1px; border-color: rgba(239, 68, 68, 0.3);
                        Text { text: "⚠ Passwords do not match"; font-size: Sizes.font-sm; color: Palette.red; vertical-alignment: center; horizontal-alignment: left; x: 14px; }
                    }
                }

                // ── ACCESS & SSH ─────────────────────────────────────────
                SectionHeader { title: "Access & SSH"; open: s-access-ssh-open; toggle => { s-access-ssh-open = !s-access-ssh-open; } }
                if !s-access-ssh-open && (ssh-install-server || user-groups != "" || user-shell != ""): CollapsedSummary {
                    summary: (ssh-install-server ? "SSH: on" : "SSH: off") + (user-groups != "" ? "  ·  groups: " + user-groups : "") + (user-shell != "" ? "  ·  shell: " + user-shell : "");
                }
                if s-access-ssh-open: VerticalLayout {
                    spacing: 12px;
                    FieldLabel { text: "AUTHORIZED SSH KEYS  (one per line)"; }
                    FieldTextarea { value <=> ssh-keys; hint: "ssh-ed25519 AAAA… user@host"; enabled: !running; }
                    FieldHelp { text: "Paste one public key per line. Leave blank if you plan to log in another way."; }
                    HorizontalLayout { spacing: 24px; CheckBox { text: "Install SSH server"; checked <=> ssh-install-server; enabled: !running; } CheckBox { text: "Allow password authentication"; checked <=> ssh-password-auth; enabled: !running; } }
                    HorizontalLayout {
                        spacing: 16px;
                        VerticalLayout { spacing: 4px; FieldLabel { text: "GROUPS  (one per line)"; } FieldTextarea { value <=> user-groups; hint: "docker\nsudo"; enabled: !running; changed(_t) => { field-edited("user_groups"); } } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "LOGIN SHELL"; } FieldInput { value <=> user-shell; hint: "/bin/bash"; enabled: !running; changed(_t) => { field-edited("user_shell"); } } }
                    }
                    FieldHelp { text: "ForgeISO fills in your private group plus " + (distro == "fedora" || distro == "arch" ? "wheel" : "sudo") + " for admin access once you choose a username."; }
                    CheckBox { text: "Grant passwordless sudo (NOPASSWD:ALL)"; checked <=> sudo-nopasswd; enabled: !running; }
                }

                // ── NETWORK ───────────────────────────────────────────────
                SectionHeader { title: "Network"; open: s-network-open; toggle => { s-network-open = !s-network-open; } }
                if !s-network-open && (dns-servers != "" || static-ip != "" || http-proxy != ""): CollapsedSummary {
                    summary: (static-ip != "" ? "IP: " + static-ip : "DHCP") + (dns-servers != "" ? "  ·  DNS: " + dns-servers : "") + (http-proxy != "" ? "  ·  proxy: on" : "");
                }
                if s-network-open: VerticalLayout {
                    spacing: 12px;
                    HorizontalLayout { spacing: 16px;
                        VerticalLayout { spacing: 4px; FieldLabel { text: "DNS SERVERS"; } FieldInput { value <=> dns-servers; hint: "1.1.1.1, 8.8.8.8"; enabled: !running; } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "NTP SERVERS"; } FieldInput { value <=> ntp-servers; hint: "pool.ntp.org"; enabled: !running; } }
                    }
                    HorizontalLayout { spacing: 16px;
                        VerticalLayout { spacing: 4px; FieldLabel { text: "STATIC IP / CIDR"; } FieldInput { value <=> static-ip; hint: "192.168.1.100/24  (blank = DHCP)"; enabled: !running; } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "GATEWAY"; } FieldInput { value <=> gateway; hint: "192.168.1.1"; enabled: !running; } }
                    }
                    HorizontalLayout { spacing: 16px;
                        VerticalLayout { spacing: 4px; FieldLabel { text: "HTTP PROXY"; } FieldInput { value <=> http-proxy; hint: "http://proxy:3128"; enabled: !running; } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "HTTPS PROXY"; } FieldInput { value <=> https-proxy; hint: "http://proxy:3128"; enabled: !running; } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "NO PROXY"; } FieldInput { value <=> no-proxy; hint: "localhost,127.0.0.1"; enabled: !running; } }
                    }
                }

                // ── SYSTEM ────────────────────────────────────────────────
                SectionHeader { title: "System"; open: s-system-open; toggle => { s-system-open = !s-system-open; } }
                if !s-system-open && (timezone != "" || locale != "" || keyboard-layout != ""): CollapsedSummary {
                    summary: (timezone != "" ? "tz: " + timezone : "") + (locale != "" ? (timezone != "" ? "  ·  " : "") + "locale: " + locale : "") + (keyboard-layout != "" ? "  ·  kbd: " + keyboard-layout : "");
                }
                if s-system-open: VerticalLayout {
                    spacing: 12px;
                    HorizontalLayout { spacing: 16px;
                        VerticalLayout { spacing: 4px; FieldLabel { text: "TIMEZONE"; } FieldInput { value <=> timezone; hint: "America/New_York"; enabled: !running; } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "LOCALE"; } FieldInput { value <=> locale; hint: "en_US.UTF-8"; enabled: !running; } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "KEYBOARD LAYOUT"; } FieldInput { value <=> keyboard-layout; hint: "us"; enabled: !running; } }
                    }
                    HorizontalLayout { spacing: 16px;
                        VerticalLayout { spacing: 4px; FieldLabel { text: "STORAGE LAYOUT"; } FieldInput { value <=> storage-layout; hint: "lvm  /  direct"; enabled: !running; } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "APT MIRROR"; } FieldInput { value <=> apt-mirror; hint: "https://mirror.example.com/ubuntu"; enabled: !running; } }
                    }
                }

                // ── PACKAGES ──────────────────────────────────────────────
                SectionHeader { title: "Packages"; open: s-packages-open; toggle => { s-packages-open = !s-packages-open; } }
                if !s-packages-open && packages != "": CollapsedSummary { summary: packages; }
                if s-packages-open: VerticalLayout {
                    spacing: 12px;
                    FieldLabel { text: "PACKAGES  (space-separated)"; }
                    FieldTextarea { value <=> packages; hint: "curl git vim htop"; enabled: !running; changed(_t) => { field-edited("packages"); } }
                    FieldHelp { text: "Short list of must-have packages. You can add more later."; }
                    FieldLabel { text: "EXTRA APT / DNF / PACMAN REPOS  (one per line)"; }
                    FieldTextarea { value <=> apt-repos; hint: "ppa:ondrej/php\ndeb https://…"; enabled: !running; }
                }

                // ── FIREWALL ──────────────────────────────────────────────
                SectionHeader { title: "Firewall"; open: s-firewall-open; toggle => { s-firewall-open = !s-firewall-open; } }
                if !s-firewall-open && firewall-enabled: CollapsedSummary {
                    summary: "Firewall: on" + (firewall-policy != "" ? "  ·  policy: " + firewall-policy : "") + (allow-ports != "" ? "  ·  allow: " + allow-ports : "");
                }
                if s-firewall-open: VerticalLayout {
                    spacing: 12px;
                    CheckBox { text: "Enable firewall"; checked <=> firewall-enabled; enabled: !running; }
                    if firewall-enabled: VerticalLayout {
                        spacing: 12px;
                        VerticalLayout { spacing: 4px; FieldLabel { text: "DEFAULT POLICY"; } FieldInput { value <=> firewall-policy; hint: "deny  (or allow / reject)"; enabled: !running; changed(_t) => { field-edited("firewall_policy"); } } }
                        HorizontalLayout { spacing: 16px;
                            VerticalLayout { spacing: 4px; FieldLabel { text: "ALLOWED PORTS  (space-separated)"; } FieldInput { value <=> allow-ports; hint: "22 80 443"; enabled: !running; changed(_t) => { field-edited("allow_ports"); } } }
                            VerticalLayout { spacing: 4px; FieldLabel { text: "DENIED PORTS"; } FieldInput { value <=> deny-ports; hint: "23 21"; enabled: !running; } }
                        }
                    }
                }

                // ── SERVICES & CONTAINERS ─────────────────────────────────
                SectionHeader { title: "Services & Containers"; open: s-services-containers-open; toggle => { s-services-containers-open = !s-services-containers-open; } }
                if !s-services-containers-open && (docker || podman || enable-services != ""): CollapsedSummary {
                    summary: (docker && podman ? "Docker + Podman" : docker ? "Docker" : podman ? "Podman" : "") + (enable-services != "" ? (docker || podman ? "  ·  " : "") + "enable: " + enable-services : "");
                }
                if s-services-containers-open: VerticalLayout {
                    spacing: 12px;
                    HorizontalLayout { spacing: 16px;
                        VerticalLayout { spacing: 4px; FieldLabel { text: "ENABLE  (one per line)"; } FieldTextarea { value <=> enable-services; hint: "docker\nnginx"; enabled: !running; changed(_t) => { field-edited("enable_services"); } } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "DISABLE  (one per line)"; } FieldTextarea { value <=> disable-services; hint: "snapd"; enabled: !running; changed(_t) => { field-edited("disable_services"); } } }
                    }
                    HorizontalLayout { spacing: 24px;
                        CheckBox { text: "Install Docker"; checked <=> docker; enabled: !running; toggled => { docker-changed(); } }
                        CheckBox { text: "Install Podman"; checked <=> podman; enabled: !running; }
                    }
                    if docker: VerticalLayout {
                        spacing: 4px;
                        FieldLabel { text: "ADD USERS TO DOCKER GROUP  (one per line)"; }
                        FieldInput { value <=> docker-users; hint: "admin"; enabled: !running; changed(_t) => { field-edited("docker_users"); } }
                        FieldHelp { text: "ForgeISO pre-fills this with the primary username unless you override it."; }
                    }
                }

                // ── STORAGE & BOOT ────────────────────────────────────────
                SectionHeader { title: "Storage & Boot"; open: s-storage-boot-open; toggle => { s-storage-boot-open = !s-storage-boot-open; } }
                if !s-storage-boot-open && (encrypt || swap-size-mb != "" || storage-layout != ""): CollapsedSummary {
                    summary: (storage-layout != "" ? "layout: " + storage-layout : "") + (swap-size-mb != "" ? (storage-layout != "" ? "  ·  " : "") + "swap: " + swap-size-mb + " MB" : "") + (encrypt ? "  ·  LUKS: on" : "");
                }
                if s-storage-boot-open: VerticalLayout {
                    spacing: 12px;
                    FieldLabel { text: "SWAP SIZE  (MB, blank = no swap)"; }
                    FieldInput { value <=> swap-size-mb; hint: "2048"; enabled: !running; }
                    CheckBox { text: "Enable LUKS disk encryption"; checked <=> encrypt; enabled: !running; }
                    if encrypt: VerticalLayout { spacing: 4px; FieldLabel { text: "LUKS PASSPHRASE"; } FieldInput { value <=> encrypt-passphrase; password: true; hint: "••••••••"; enabled: !running; } }
                    VerticalLayout { spacing: 4px; FieldLabel { text: "CUSTOM MOUNTS  (one fstab entry per line)"; } FieldTextarea { value <=> mounts; hint: "/dev/sdb1  /data  ext4  defaults  0 2"; enabled: !running; } }
                    HorizontalLayout { spacing: 16px;
                        VerticalLayout { spacing: 4px; FieldLabel { text: "GRUB TIMEOUT  (seconds)"; } FieldInput { value <=> grub-timeout; hint: "5"; enabled: !running; } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "EXTRA KERNEL ARGS"; } FieldInput { value <=> grub-cmdline; hint: "quiet splash"; enabled: !running; } }
                    }
                }

                // ── ADVANCED ──────────────────────────────────────────────
                SectionHeader { title: "Advanced"; open: s-advanced-open; toggle => { s-advanced-open = !s-advanced-open; } }
                if !s-advanced-open && (run-commands != "" || late-commands != "" || no-user-interaction): CollapsedSummary {
                    summary: (no-user-interaction ? "unattended  " : "") + (run-commands != "" ? "run-commands: on" : "") + (late-commands != "" ? (run-commands != "" ? "  ·  " : "") + "late-commands: on" : "");
                }
                if s-advanced-open: VerticalLayout {
                    spacing: 12px;
                    FieldLabel { text: "RUN COMMANDS  (before install)"; }
                    FieldTextarea { value <=> run-commands; hint: "echo 'setup starting'"; enabled: !running; }
                    FieldHelp { text: "Simple pre-install tasks. Leave blank unless you need custom behavior."; }
                    FieldLabel { text: "LATE COMMANDS  (after install, in chroot)"; }
                    FieldTextarea { value <=> late-commands; hint: "curtin in-target -- apt-get install -y vim"; enabled: !running; }
                    FieldLabel { text: "SYSCTL PAIRS  (key=value, one per line)"; }
                    FieldTextarea { value <=> sysctl-pairs; hint: "vm.swappiness=10\nnet.ipv4.ip_forward=1"; enabled: !running; }
                    CheckBox { text: "Unattended installation (no user interaction at all)"; checked <=> no-user-interaction; enabled: !running; }
                }

                // ── OUTPUT ────────────────────────────────────────────────
                SectionHeader { title: "Output (required)"; open: s-output-open; toggle => { s-output-open = !s-output-open; } }
                if s-output-open: VerticalLayout {
                    spacing: 12px;
                    HorizontalLayout {
                        spacing: 10px;
                        VerticalLayout {
                            spacing: 4px;
                            FieldLabel { text: "OUTPUT DIRECTORY"; }
                            Rectangle {
                                height: Sizes.btn-md;
                                border-radius: Sizes.radius-sm;
                                background: Palette.input;
                                border-width: 1px;
                                border-color: Palette.border;
                                HorizontalLayout { padding-left: 14px;
                                    Text { text: output-dir; font-size: Sizes.font-sm; color: Palette.text; vertical-alignment: center; overflow: elide; }
                                }
                            }
                        }
                        VerticalLayout {
                            alignment: end;
                            Rectangle {
                                width: 100px; height: Sizes.btn-md; border-radius: Sizes.radius-sm;
                                background: out-brw-ta.has-hover && !running
                                    ? rgba(99, 102, 241, 0.18) : rgba(99, 102, 241, 0.08);
                                border-width: 1.5px; border-color: out-brw-ta.has-hover && !running
                                    ? Palette.accent : rgba(99, 102, 241, 0.4);
                                opacity: running ? 0.4 : 1.0;
                                animate background { duration: 100ms; }
                                animate border-color { duration: 100ms; }
                                Text { text: "Browse…"; font-size: Sizes.font-sm; font-weight: 600; color: Palette.accent; vertical-alignment: center; horizontal-alignment: center; }
                                out-brw-ta := TouchArea { enabled: !running; mouse-cursor: running ? MouseCursor.default : MouseCursor.pointer; clicked => { browse-output-dir(); } }
                            }
                        }
                    }
                    FieldHelp { text: "ForgeISO writes the finished ISO here."; }
                    HorizontalLayout { spacing: 16px;
                        VerticalLayout { spacing: 4px; FieldLabel { text: "OUTPUT FILENAME"; } FieldInput { value <=> out-name; hint: "forgeiso-local.iso"; enabled: !running; } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "VOLUME LABEL  (max 32 chars)"; } FieldInput { value <=> output-label; hint: "MYISO"; enabled: !running; } }
                        VerticalLayout { spacing: 4px; FieldLabel { text: "EXPECTED SHA-256  (optional)"; } FieldInput { value <=> expected-sha256; hint: "a1b2c3…"; enabled: !running; } }
                    }
                }

                // ── Continue button ───────────────────────────────────────
                Rectangle { height: 1px; background: Palette.border; opacity: 0.3; }
                HorizontalLayout {
                    alignment: start;
                    Rectangle {
                        width: 300px;
                        height: Sizes.btn-lg;
                        border-radius: Sizes.radius-md;
                        property <bool> btn-active: can-continue && !pw-live-mismatch;
                        background: btn-active
                            ? (cfg-fwd-ta.has-hover
                                ? @linear-gradient(135deg, #818cf8, #6366f1)
                                : @linear-gradient(135deg, #6366f1, #4f46e5))
                            : Palette.elevated;
                        opacity: btn-active ? 1.0 : 0.4;
                        drop-shadow-blur: btn-active ? 22px : 0px;
                        drop-shadow-color: btn-active
                            ? rgba(99, 102, 241, 0.3) : transparent;
                        animate background { duration: 150ms; }
                        animate opacity  { duration: 200ms; }
                        animate drop-shadow-blur { duration: 300ms; }
                        Text {
                            text: "Continue to Review  →";
                            font-size: Sizes.font-sm;
                            font-weight: 700;
                            color: btn-active ? Palette.on-accent : Palette.subtle;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                        cfg-fwd-ta := TouchArea {
                            enabled: btn-active && !running;
                            mouse-cursor: btn-active && !running ? MouseCursor.pointer : MouseCursor.default;
                            clicked => { configure-continue(); }
                        }
                    }
                }
            }
        }
    }
}
