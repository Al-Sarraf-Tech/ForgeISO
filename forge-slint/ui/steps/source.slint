import { Palette, Sizes } from "../theme.slint";
import { FButton, FIconButton, FBadge, FDivider, FSectionLabel } from "../components/design_system.slint";
import { ScrollView } from "std-widgets.slint";

export struct PresetCard {
    id: string,
    emoji: string,
    name: string,
    desc: string,
}

component DistroCard inherits Rectangle {
    in property <PresetCard> card;
    in property <bool>       selected: false;
    in property <bool>       running: false;
    callback clicked();

    width: 180px;
    height: 110px;
    border-radius: Sizes.radius-md;
    background: selected ? rgba(69, 194, 107, 0.08)
              : hovered && !running ? Palette.active
              : Palette.elevated;
    border-width: selected ? 1.5px : 1px;
    border-color: selected ? Palette.green
               : hovered && !running ? Palette.border-focus
               : Palette.border-subtle;
    opacity: running ? 0.6 : 1.0;
    animate background { duration: 150ms; }
    animate border-color { duration: 150ms; }
    animate opacity { duration: 150ms; }

    property <bool> hovered: touch.has-hover;

    VerticalLayout {
        alignment: center;
        spacing: Sizes.space-1;
        padding-left: Sizes.space-4;
        padding-right: Sizes.space-4;
        padding-top: Sizes.space-3;
        padding-bottom: Sizes.space-3;

        if card.emoji != "": Text {
            text: card.emoji;
            font-size: 22px;
            horizontal-alignment: center;
        }
        Text {
            text: card.name;
            font-size: Sizes.font-md;
            font-weight: 600;
            color: selected ? Palette.green : Palette.text;
            horizontal-alignment: center;
            animate color { duration: 150ms; }
        }
        Text {
            text: card.desc;
            font-size: Sizes.font-xs;
            color: Palette.muted;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
    }

    touch := TouchArea {
        enabled: !running;
        mouse-cursor: running ? MouseCursor.default : MouseCursor.pointer;
        clicked => { root.clicked(); }
    }
}

export component StepSource inherits Rectangle {
    in property <[PresetCard]> presets-row1;
    in property <[PresetCard]> presets-row2;
    in property <string>       source-path;
    in property <string>       selected-preset;
    in property <string>       detected-distro;
    in property <bool>         running: false;
    in property <bool>         can-continue: false;
    callback preset-clicked(string);
    callback browse-clicked();
    callback source-changed(string);
    callback continue-clicked();
    callback clear-clicked();

    background: Palette.bg;

    ScrollView {
        VerticalLayout {
            padding: Sizes.space-10;
            spacing: Sizes.space-8;
            alignment: start;

            // -- Title -------------------------------------------------------
            VerticalLayout {
                spacing: Sizes.space-2;
                Text {
                    text: "Build Your ISO";
                    font-size: Sizes.font-3xl;
                    font-weight: 700;
                    color: Palette.text;
                    letter-spacing: -0.5px;
                }
                Text {
                    text: "Inject unattended install config into any Linux ISO \u{2014} Ubuntu, Fedora, Arch, Mint and more.";
                    font-size: Sizes.font-md;
                    color: Palette.muted;
                }
            }

            // -- Distro grid -------------------------------------------------
            VerticalLayout {
                spacing: Sizes.space-3;
                FSectionLabel {
                    text: "POPULAR DISTRIBUTIONS";
                    letter-spacing: 1.5px;
                }

                // Row 1
                HorizontalLayout {
                    spacing: Sizes.space-3;
                    alignment: center;
                    for card in presets-row1: DistroCard {
                        card: card;
                        selected: selected-preset == card.id;
                        running: running;
                        clicked => { preset-clicked(card.id); }
                    }
                }

                // Row 2 (only rendered if non-empty)
                if presets-row2.length > 0: HorizontalLayout {
                    spacing: Sizes.space-3;
                    alignment: center;
                    for card in presets-row2: DistroCard {
                        card: card;
                        selected: selected-preset == card.id;
                        running: running;
                        clicked => { preset-clicked(card.id); }
                    }
                }
            }

            // -- Manual path entry -------------------------------------------
            VerticalLayout {
                spacing: Sizes.space-3;
                FDivider {
                    label: "or enter a path / URL directly";
                }

                HorizontalLayout {
                    spacing: Sizes.space-2;
                    alignment: start;

                    // Path input
                    Rectangle {
                        height: 42px;
                        border-radius: Sizes.radius-sm;
                        background: Palette.bg;
                        border-width: 1px;
                        border-color: path-input.has-focus ? Palette.accent : Palette.border;
                        animate border-color { duration: 150ms; }
                        if source-path == "" && !path-input.has-focus: Text {
                            x: Sizes.space-3;
                            y: 0;
                            width: parent.width - Sizes.space-6;
                            height: parent.height;
                            text: "/path/to/ubuntu.iso  or  https://releases.ubuntu.com/\u{2026}";
                            font-size: Sizes.font-sm;
                            color: Palette.subtle;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                        path-input := TextInput {
                            x: Sizes.space-3;
                            y: (parent.height - self.preferred-height) / 2;
                            width: parent.width - Sizes.space-6;
                            text: source-path;
                            font-size: Sizes.font-sm;
                            color: Palette.text;
                            selection-background-color: Palette.accent;
                            selection-foreground-color: Palette.on-accent;
                            single-line: true;
                            enabled: !running;
                            edited => { source-changed(path-input.text); }
                            accepted => {
                                if (can-continue && !running) { continue-clicked(); }
                            }
                        }
                    }

                    // Browse button
                    FButton {
                        label: "Browse\u{2026}";
                        variant: "secondary";
                        enabled: !running;
                        width: 90px;
                        height: 42px;
                        clicked => { browse-clicked(); }
                    }

                    // Clear button
                    if source-path != "": FIconButton {
                        icon: "\u{2715}";
                        variant: "destructive";
                        enabled: !running;
                        width: 42px;
                        height: 42px;
                        clicked => { clear-clicked(); }
                    }
                }

                // Detected distro badge
                if detected-distro != "": HorizontalLayout {
                    alignment: start;
                    FBadge {
                        text: "\u{2713} Detected: " + detected-distro;
                        variant: "success";
                        height: 26px;
                        border-radius: 13px;
                    }
                }
            }

            // -- Continue button ---------------------------------------------
            HorizontalLayout {
                alignment: start;
                FButton {
                    label: "Continue to Configure Installer \u{2192}";
                    variant: "primary";
                    enabled: can-continue && !running;
                    width: 300px;
                    height: 46px;
                    clicked => { continue-clicked(); }
                }
            }
        }
    }
}
