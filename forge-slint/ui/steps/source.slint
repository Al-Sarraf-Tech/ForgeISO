import { Palette, Sizes } from "../theme.slint";
import { ScrollView } from "std-widgets.slint";

export struct PresetCard {
    id: string,
    emoji: string,
    name: string,
    desc: string,
}

component DistroCard inherits Rectangle {
    in property <PresetCard> card;
    in property <bool>       selected: false;
    in property <bool>       running: false;
    callback clicked();

    width: 196px;
    height: 148px;
    border-radius: Sizes.radius-lg;
    background: selected ? rgba(99, 102, 241, 0.10)
              : hovered && !running ? Palette.surface-hover
              : Palette.surface;
    border-width: selected ? 2px : 1px;
    border-color: selected ? rgba(99, 102, 241, 0.65)
               : hovered && !running ? rgba(99, 102, 241, 0.35)
               : Palette.border;
    opacity: running ? 0.35 : 1.0;
    clip: true;
    drop-shadow-blur: selected ? 28px : hovered && !running ? 14px : 0px;
    drop-shadow-color: selected ? rgba(99, 102, 241, 0.30)
                     : hovered && !running ? rgba(99, 102, 241, 0.14)
                     : transparent;
    animate background { duration: 200ms; }
    animate border-color { duration: 200ms; }
    animate border-width { duration: 200ms; }
    animate opacity { duration: 200ms; }
    animate drop-shadow-blur { duration: 300ms; }
    animate drop-shadow-color { duration: 300ms; }

    property <bool> hovered: touch.has-hover;

    // Selected accent bar at top
    if selected: Rectangle {
        height: 3px;
        background: @linear-gradient(90deg, #6366f1, #818cf8);
    }

    VerticalLayout {
        alignment: center;
        spacing: 10px;
        padding: 18px;

        Text {
            text: card.emoji;
            font-size: 34px;
            horizontal-alignment: center;
        }
        Text {
            text: card.name;
            font-size: Sizes.font-sm;
            font-weight: 700;
            color: Palette.text;
            horizontal-alignment: center;
        }
        Text {
            text: card.desc;
            font-size: Sizes.font-xs;
            color: Palette.muted;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
        if selected: Text {
            text: "✓ Selected";
            font-size: Sizes.font-xs;
            color: Palette.accent;
            font-weight: 700;
            horizontal-alignment: center;
        }
    }

    touch := TouchArea {
        enabled: !running;
        mouse-cursor: running ? MouseCursor.default : MouseCursor.pointer;
        clicked => { root.clicked(); }
    }
}

export component StepSource inherits Rectangle {
    in property <[PresetCard]> presets-row1;
    in property <[PresetCard]> presets-row2;
    in property <string>       source-path;
    in property <string>       selected-preset;
    in property <string>       detected-distro;
    in property <bool>         running: false;
    in property <bool>         can-continue: false;
    callback preset-clicked(string);
    callback browse-clicked();
    callback source-changed(string);
    callback continue-clicked();
    callback clear-clicked();

    background: Palette.bg;

    ScrollView {
        VerticalLayout {
            padding-left: 52px;
            padding-right: 52px;
            padding-top: 40px;
            padding-bottom: 40px;
            spacing: 32px;
            alignment: start;

            // ── Title ────────────────────────────────────────────────────
            VerticalLayout {
                spacing: 8px;
                Text {
                    text: "Build Your ISO";
                    font-size: Sizes.font-2xl;
                    font-weight: 800;
                    color: Palette.text;
                    letter-spacing: -0.5px;
                }
                Text {
                    text: "Inject unattended install config into any Linux ISO — Ubuntu, Fedora, Arch, Mint and more.";
                    font-size: Sizes.font-md;
                    color: Palette.muted;
                    wrap: word-wrap;
                }
            }

            // ── Distro grid ─────────────────────────────────────────────
            VerticalLayout {
                spacing: 18px;
                Text {
                    text: "POPULAR DISTRIBUTIONS";
                    font-size: Sizes.font-xs;
                    font-weight: 700;
                    color: Palette.subtle;
                    letter-spacing: 1.5px;
                }

                // Row 1
                HorizontalLayout {
                    spacing: 14px;
                    alignment: center;
                    for card in presets-row1: DistroCard {
                        card: card;
                        selected: selected-preset == card.id;
                        running: running;
                        clicked => { preset-clicked(card.id); }
                    }
                }

                // Row 2
                if presets-row2.length > 0: HorizontalLayout {
                    spacing: 14px;
                    alignment: center;
                    for card in presets-row2: DistroCard {
                        card: card;
                        selected: selected-preset == card.id;
                        running: running;
                        clicked => { preset-clicked(card.id); }
                    }
                }
            }

            // ── Manual path entry ───────────────────────────────────────
            VerticalLayout {
                spacing: 16px;

                // Divider
                HorizontalLayout {
                    spacing: 14px;
                    padding-top: 4px;
                    padding-bottom: 4px;
                    VerticalLayout {
                        alignment: center;
                        Rectangle { height: 1px; background: Palette.border; }
                    }
                    Text {
                        text: "or enter a path / URL directly";
                        font-size: Sizes.font-xs;
                        color: Palette.subtle;
                        vertical-alignment: center;
                        horizontal-stretch: 0;
                    }
                    VerticalLayout {
                        alignment: center;
                        Rectangle { height: 1px; background: Palette.border; }
                    }
                }

                HorizontalLayout {
                    spacing: 10px;
                    alignment: start;

                    // Path input
                    Rectangle {
                        height: Sizes.btn-lg;
                        border-radius: Sizes.radius-md;
                        background: Palette.input;
                        border-width: 1.5px;
                        border-color: path-input.has-focus ? Palette.accent : Palette.border;
                        drop-shadow-blur: path-input.has-focus ? 14px : 0px;
                        drop-shadow-color: path-input.has-focus
                            ? rgba(99, 102, 241, 0.18) : transparent;
                        animate border-color { duration: 180ms; }
                        animate drop-shadow-blur { duration: 250ms; }
                        if source-path == "" && !path-input.has-focus: Text {
                            x: 16px; y: 0;
                            width: parent.width - 32px;
                            height: parent.height;
                            text: "/path/to/ubuntu.iso  or  https://releases.ubuntu.com/…";
                            font-size: Sizes.font-sm;
                            color: Palette.subtle;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                        path-input := TextInput {
                            x: 16px;
                            y: (parent.height - self.preferred-height) / 2;
                            width: parent.width - 32px;
                            text: source-path;
                            font-size: Sizes.font-sm;
                            color: Palette.text;
                            selection-background-color: Palette.accent;
                            selection-foreground-color: Palette.on-accent;
                            single-line: true;
                            enabled: !running;
                            edited => { source-changed(path-input.text); }
                        }
                    }

                    // Browse button
                    Rectangle {
                        width: 110px;
                        height: Sizes.btn-lg;
                        border-radius: Sizes.radius-md;
                        background: browse-ta.has-hover && !running
                            ? rgba(99, 102, 241, 0.18) : rgba(99, 102, 241, 0.08);
                        border-width: 1.5px;
                        border-color: browse-ta.has-hover && !running
                            ? Palette.accent : rgba(99, 102, 241, 0.4);
                        opacity: running ? 0.4 : 1.0;
                        animate background { duration: 120ms; }
                        animate border-color { duration: 120ms; }
                        animate opacity { duration: 150ms; }
                        Text {
                            text: "Browse…";
                            font-size: Sizes.font-sm;
                            font-weight: 600;
                            color: Palette.accent;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                        browse-ta := TouchArea {
                            enabled: !running;
                            mouse-cursor: running ? MouseCursor.default : MouseCursor.pointer;
                            clicked => { browse-clicked(); }
                        }
                    }

                    // Clear button
                    if source-path != "": Rectangle {
                        width: Sizes.btn-lg;
                        height: Sizes.btn-lg;
                        border-radius: Sizes.radius-md;
                        background: clear-ta.has-hover && !running
                            ? rgba(239, 68, 68, 0.12) : Palette.elevated;
                        border-width: 1px;
                        border-color: clear-ta.has-hover && !running
                            ? rgba(239, 68, 68, 0.35) : Palette.border;
                        animate background { duration: 120ms; }
                        animate border-color { duration: 120ms; }
                        Text {
                            text: "✕";
                            font-size: 16px;
                            color: clear-ta.has-hover && !running ? Palette.red : Palette.muted;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                        clear-ta := TouchArea {
                            enabled: !running;
                            mouse-cursor: running ? MouseCursor.default : MouseCursor.pointer;
                            clicked => { clear-clicked(); }
                        }
                    }
                }

                // Detected distro badge
                if detected-distro != "": HorizontalLayout {
                    alignment: start;
                    Rectangle {
                        height: 32px;
                        border-radius: 16px;
                        background: rgba(99, 102, 241, 0.10);
                        border-width: 1px;
                        border-color: rgba(99, 102, 241, 0.35);
                        drop-shadow-blur: 10px;
                        drop-shadow-color: rgba(99, 102, 241, 0.12);
                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 4px;
                            alignment: center;
                            Text {
                                text: "✓ Detected: " + detected-distro;
                                font-size: Sizes.font-sm;
                                color: Palette.accent;
                                font-weight: 600;
                            }
                        }
                    }
                }
            }

            // ── Continue button ─────────────────────────────────────────
            HorizontalLayout {
                alignment: start;
                Rectangle {
                    width: 320px;
                    height: Sizes.btn-lg;
                    border-radius: Sizes.radius-md;
                    background: can-continue
                        ? (cont-ta.has-hover
                            ? @linear-gradient(135deg, #818cf8, #6366f1)
                            : @linear-gradient(135deg, #6366f1, #4f46e5))
                        : Palette.elevated;
                    opacity: can-continue ? 1.0 : 0.4;
                    drop-shadow-blur: can-continue ? 22px : 0px;
                    drop-shadow-color: can-continue
                        ? rgba(99, 102, 241, 0.3) : transparent;
                    animate background { duration: 150ms; }
                    animate opacity  { duration: 200ms; }
                    animate drop-shadow-blur { duration: 300ms; }

                    HorizontalLayout {
                        alignment: center;
                        spacing: 8px;
                        Text {
                            text: "Continue to Configure  →";
                            font-size: Sizes.font-sm;
                            font-weight: 700;
                            color: can-continue ? Palette.on-accent : Palette.subtle;
                        }
                    }
                    cont-ta := TouchArea {
                        enabled: can-continue && !running;
                        mouse-cursor: can-continue && !running ? MouseCursor.pointer : MouseCursor.default;
                        clicked => { continue-clicked(); }
                    }
                }
            }
        }
    }
}
