// ── ForgeISO dark palette ────────────────────────────────────────────────────
// All colours are centralised here. Import this file in every component.

export global Palette {
    // Backgrounds — high contrast between layers
    out property <color> bg:       #0a0a0f;   // page background (deepest)
    out property <color> surface:  #16171f;   // cards — clearly distinct from bg
    out property <color> panel:    #101118;   // header / step bar / sidebars
    out property <color> elevated: #222334;   // buttons, chips, dropdowns
    out property <color> input:    #1c1d2b;   // input field background

    // Borders — more visible
    out property <color> border:       #2d2e40;
    out property <color> border-focus: #6366f1;

    // Semantic — vivid, saturated
    out property <color> accent: #6366f1;    // indigo — distinctive from typical blue
    out property <color> green:  #10b981;    // emerald
    out property <color> red:    #f43f5e;    // rose
    out property <color> amber:  #f59e0b;    // amber

    // Text — high contrast
    out property <color> text:           #f8fafc;
    out property <color> text-secondary: #a1a1b5;
    out property <color> muted:          #6b6b80;
    out property <color> subtle:         #4a4a5e;
    out property <color> on-accent:      #ffffff;

    // Interactive states
    out property <color> active:        #2a2b3d;
    out property <color> surface-hover: #1e1f2d;
}

export global Sizes {
    // Border radii — generous for modern feel
    out property <length> radius-sm:  8px;
    out property <length> radius-md:  12px;
    out property <length> radius-lg:  16px;
    out property <length> radius-xl:  20px;

    // Spacing
    out property <length> gap-xs: 4px;
    out property <length> gap-sm: 8px;
    out property <length> gap-md: 14px;
    out property <length> gap-lg: 24px;

    // Typography
    out property <length> font-2xs: 11px;
    out property <length> font-xs:  12px;
    out property <length> font-sm:  14px;
    out property <length> font-md:  15px;
    out property <length> font-lg:  18px;
    out property <length> font-xl:  24px;
    out property <length> font-2xl: 32px;

    // Standardised button heights
    out property <length> btn-sm:  36px;
    out property <length> btn-md:  42px;
    out property <length> btn-lg:  50px;
}
