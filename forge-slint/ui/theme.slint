// ── ForgeISO dark palette ────────────────────────────────────────────────────
// All colours are centralised here. Import this file in every component.

export global Palette {
    // Backgrounds
    out property <color> bg:       #0d1117;
    out property <color> surface:  #161b22;
    out property <color> panel:    #0a0e14;
    out property <color> elevated: #21262d;

    // Borders
    out property <color> border:       #30363d;
    out property <color> border-focus: #388bfd;

    // Semantic
    out property <color> accent: #2f81f7;
    out property <color> green:  #3fb950;
    out property <color> red:    #f85149;
    out property <color> amber:  #d29922;

    // Text
    out property <color> text:          #e6edf3;
    out property <color> text-secondary: #b1bac4;
    out property <color> muted:         #8b949e;
    out property <color> subtle:        #6e7681;
    out property <color> on-accent:     #ffffff;

    // Interactive states
    out property <color> active: #2d333b;
}

export global Sizes {
    out property <length> radius-sm:  6px;
    out property <length> radius-md:  10px;
    out property <length> radius-lg:  14px;
    out property <length> radius-xl:  18px;

    out property <length> gap-xs: 4px;
    out property <length> gap-sm: 8px;
    out property <length> gap-md: 14px;
    out property <length> gap-lg: 24px;

    out property <length> font-2xs: 10px;
    out property <length> font-xs:  11px;
    out property <length> font-sm:  12px;
    out property <length> font-md:  14px;
    out property <length> font-lg:  16px;
    out property <length> font-xl:  20px;
    out property <length> font-2xl: 26px;
}
