import { Palette, Sizes } from "theme.slint";
import { ScrollView } from "std-widgets.slint";
import { Header }    from "components/header.slint";
import { StepBar }   from "components/step_bar.slint";
import { LogPanel, LogEntry } from "components/log_panel.slint";
import { StepSource, PresetCard } from "steps/source.slint";
import { StepConfigure }  from "steps/configure.slint";
import { StepBuild }      from "steps/build.slint";
import { StepCheck }      from "steps/check.slint";
import { FormState } from "globals/form_state.slint";
import { AppState }  from "globals/app_state.slint";

export { LogEntry, PresetCard, FormState, AppState }

export component AppWindow inherits Window {
    title: "ForgeISO";
    preferred-width: 1440px;
    preferred-height: 900px;
    min-width: 1100px;
    min-height: 700px;
    background: Palette.bg;

    // ── Model properties (stay on window — ModelRc works best here) ────────
    in property <[LogEntry]>     log-entries;
    in property <[PresetCard]>   presets-row1;
    in property <[PresetCard]>   presets-row2;

    // ── Callbacks ───────────────────────────────────────────────────────
    // Header
    callback cancel-job();
    callback doctor-toggle();
    // Step bar
    callback step-bar-clicked(int);
    // Source
    callback preset-clicked(string);
    callback browse-source();
    callback source-changed(string);
    callback source-continue();
    callback clear-source();
    // Configure
    callback browse-output-dir();
    callback configure-continue();
    callback configure-back();
    callback apply-defaults();
    callback reset-defaults();
    callback field-edited(string);
    callback username-changed(string);
    callback docker-changed();
    // Build
    callback build-back();
    callback build-back-to-source();
    callback build-run();
    callback build-view-results();
    // Optional checks
    callback browse-verify-source();
    callback check-back();
    callback run-verify();
    callback run-iso9660();
    callback run-verify-output();
    callback copy-sha256();
    callback open-folder();
    callback clear-forms();
    // Log
    callback log-toggle();
    callback log-filter-toggle();

    // ── Derived helper: distro display label ─────────────────────────────
    property <string> distro-display: FormState.distro == "fedora" ? "Fedora / RHEL \u{2014} Kickstart"
                                    : FormState.distro == "arch"   ? "Arch Linux \u{2014} archinstall"
                                    : FormState.distro == "mint"   ? "Linux Mint \u{2014} preseed"
                                    : "Ubuntu / Debian \u{2014} cloud-init";

    // ── Layout ──────────────────────────────────────────────────────────
    VerticalLayout {
        Header {
            job-phase: AppState.job-phase;
            job-percent: AppState.job-percent;
            job-running: AppState.job-running;
            status-text: AppState.status-text;
            status-is-error: AppState.status-is-error;
            doctor-open: AppState.doctor-open;
            cancel => { root.cancel-job(); }
            doctor-toggled => { root.doctor-toggle(); }
        }

        StepBar {
            current-step: AppState.current-step;
            step1-done: AppState.step1-done;
            step2-done: AppState.step2-done;
            step3-done: AppState.step3-done;
            step4-done: AppState.verify-done || AppState.iso9660-done;
            job-running: AppState.job-running;
            step-clicked(s) => { root.step-bar-clicked(s); }
        }

        // ── Main body ────────────────────────────────────────────────────
        HorizontalLayout {
            // Content area — show one step at a time with fade-in
            if AppState.current-step == 1: Rectangle {
                opacity: 0.0;
                init => { self.opacity = 1.0; }
                animate opacity { duration: 200ms; easing: ease-out; }
                StepSource {
                presets-row1: root.presets-row1;
                presets-row2: root.presets-row2;
                source-path: FormState.source-path;
                selected-preset: FormState.selected-preset;
                detected-distro: FormState.detected-distro;
                running: AppState.job-running;
                can-continue: FormState.source-path != "";
                preset-clicked(id) => { root.preset-clicked(id); }
                browse-clicked => { root.browse-source(); }
                source-changed(t) => { root.source-changed(t); }
                continue-clicked => { root.source-continue(); }
                clear-clicked => { root.clear-source(); }
            }}

            if AppState.current-step == 2: Rectangle {
                opacity: 0.0;
                init => { self.opacity = 1.0; }
                animate opacity { duration: 200ms; easing: ease-out; }
                StepConfigure {
                source-display: FormState.source-path;
                distro: FormState.distro;
                selected-preset-name: FormState.selected-preset-name;
                distro-display: root.distro-display;
                defaults-summary: AppState.defaults-summary;
                hostname <=> FormState.hostname;
                username <=> FormState.username;
                password <=> FormState.password;
                password-confirm <=> FormState.password-confirm;
                realname <=> FormState.realname;
                passwords-match: FormState.password == "" || FormState.password == FormState.password-confirm;
                ssh-keys <=> FormState.ssh-keys;
                ssh-password-auth <=> FormState.ssh-password-auth;
                ssh-install-server <=> FormState.ssh-install-server;
                dns-servers <=> FormState.dns-servers;
                ntp-servers <=> FormState.ntp-servers;
                static-ip <=> FormState.static-ip;
                gateway <=> FormState.gateway;
                http-proxy <=> FormState.http-proxy;
                https-proxy <=> FormState.https-proxy;
                no-proxy <=> FormState.no-proxy;
                timezone <=> FormState.timezone;
                locale <=> FormState.locale;
                keyboard-layout <=> FormState.keyboard-layout;
                storage-layout <=> FormState.storage-layout;
                apt-mirror <=> FormState.apt-mirror;
                packages <=> FormState.packages;
                apt-repos <=> FormState.apt-repos;
                dnf-repos <=> FormState.dnf-repos;
                run-commands <=> FormState.run-commands;
                late-commands <=> FormState.late-commands;
                firewall-enabled <=> FormState.firewall-enabled;
                firewall-policy <=> FormState.firewall-policy;
                allow-ports <=> FormState.allow-ports;
                deny-ports <=> FormState.deny-ports;
                user-groups <=> FormState.user-groups;
                user-shell <=> FormState.user-shell;
                sudo-nopasswd <=> FormState.sudo-nopasswd;
                enable-services <=> FormState.enable-services;
                disable-services <=> FormState.disable-services;
                docker <=> FormState.docker;
                podman <=> FormState.podman;
                docker-users <=> FormState.docker-users;
                swap-size-mb <=> FormState.swap-size-mb;
                encrypt <=> FormState.encrypt;
                encrypt-passphrase <=> FormState.encrypt-passphrase;
                mounts <=> FormState.mounts;
                grub-timeout <=> FormState.grub-timeout;
                grub-cmdline <=> FormState.grub-cmdline;
                sysctl-pairs <=> FormState.sysctl-pairs;
                output-dir <=> FormState.output-dir;
                out-name <=> FormState.out-name;
                output-label <=> FormState.output-label;
                expected-sha256 <=> FormState.expected-sha256;
                no-user-interaction <=> FormState.no-user-interaction;
                running: AppState.job-running;
                can-continue: FormState.source-path != "" && FormState.hostname != "" && FormState.username != "" && FormState.output-dir != "" && FormState.out-name != "";
                browse-output-dir => { root.browse-output-dir(); }
                configure-continue => { root.configure-continue(); }
                back-clicked => { root.configure-back(); }
                distro-changed(d) => { FormState.distro = d; }
                clear-source => { root.clear-source(); }
                apply-defaults => { root.apply-defaults(); }
                reset-defaults => { root.reset-defaults(); }
                field-edited(name) => { root.field-edited(name); }
                username-changed(u) => { root.username-changed(u); }
                docker-changed => { root.docker-changed(); }
            }
}

            if AppState.current-step == 3: Rectangle {
                opacity: 0.0;
                init => { self.opacity = 1.0; }
                animate opacity { duration: 200ms; easing: ease-out; }
                StepBuild {
                distro-display: root.distro-display;
                admin-group: FormState.distro == "fedora" || FormState.distro == "arch" ? "wheel" : "sudo";
                source: FormState.source-path;
                expected-sha256: FormState.expected-sha256;
                hostname: FormState.hostname;
                username: FormState.username;
                realname: FormState.realname;
                password-set: FormState.password != "";
                user-groups: FormState.user-groups;
                user-shell: FormState.user-shell;
                sudo-nopasswd: FormState.sudo-nopasswd;
                ssh-password-auth: FormState.ssh-password-auth;
                ssh-keys: FormState.ssh-keys;
                timezone: FormState.timezone;
                locale: FormState.locale;
                keyboard-layout: FormState.keyboard-layout;
                static-ip: FormState.static-ip;
                gateway: FormState.gateway;
                dns-servers: FormState.dns-servers;
                ntp-servers: FormState.ntp-servers;
                firewall-policy: FormState.firewall-policy;
                allow-ports: FormState.allow-ports;
                deny-ports: FormState.deny-ports;
                output-dir: FormState.output-dir;
                out-name: FormState.out-name;
                output-label: FormState.output-label;
                unattended: FormState.no-user-interaction;
                ssh-server: FormState.ssh-install-server;
                packages: FormState.packages;
                extra-repos: FormState.apt-repos != "" ? FormState.apt-repos : FormState.dnf-repos;
                enable-services: FormState.enable-services;
                disable-services: FormState.disable-services;
                firewall-on: FormState.firewall-enabled;
                docker-on: FormState.docker;
                podman-on: FormState.podman;
                docker-users: FormState.docker-users;
                encrypt-on: FormState.encrypt;
                storage-layout: FormState.storage-layout;
                mounts: FormState.mounts;
                run-commands: FormState.run-commands;
                late-commands: FormState.late-commands;
                running: AppState.job-running;
                artifact-path: AppState.artifact-path;
                artifact-sha256: AppState.artifact-sha256;
                verify-summary: AppState.step3-done
                    ? (AppState.verify-done || AppState.iso9660-done
                        ? "Verification checks complete"
                        : "")
                    : "";
                back-clicked => { root.build-back(); }
                back-to-source => { root.build-back-to-source(); }
                run-clicked => { root.build-run(); }
                view-results => { root.build-view-results(); }
                open-folder => { root.open-folder(); }
                start-over => { root.clear-forms(); }
            }}

            if AppState.current-step == 4: Rectangle {
                opacity: 0.0;
                init => { self.opacity = 1.0; }
                animate opacity { duration: 200ms; easing: ease-out; }
                StepCheck {
                verify-source <=> AppState.verify-source;
                sums-url <=> AppState.sums-url;
                artifact-path: AppState.artifact-path;
                artifact-sha256: AppState.artifact-sha256;
                verify-done: AppState.verify-done;
                verify-matched: AppState.verify-matched;
                verify-hash-display: AppState.verify-hash-display;
                iso9660-done: AppState.iso9660-done;
                iso9660-compliant: AppState.iso9660-compliant;
                iso9660-boot-bios: AppState.iso9660-boot-bios;
                iso9660-boot-uefi: AppState.iso9660-boot-uefi;
                iso9660-volume-id: AppState.iso9660-volume-id;
                running: AppState.job-running;
                output-verified: AppState.output-verified;
                output-verify-matched: AppState.output-verify-matched;
                back-clicked => { root.check-back(); }
                browse-verify-source => { root.browse-verify-source(); }
                run-verify => { root.run-verify(); }
                run-iso9660 => { root.run-iso9660(); }
                run-verify-output => { root.run-verify-output(); }
                copy-sha256 => { root.copy-sha256(); }
                open-folder => { root.open-folder(); }
                clear-forms => { root.clear-forms(); }
            }}

            // Log panel (collapsible)
            if AppState.log-open: LogPanel {
                entries: root.log-entries;
                errors-only: AppState.log-errors-only;
                error-count: AppState.log-error-count;
                filter-toggled => { root.log-filter-toggle(); }
                close-clicked => { root.log-toggle(); }
            }
        }
    }

    // ── Log toggle button (bottom-right, floating) ────────────────────────
    Rectangle {
        x: parent.width - 110px;
        y: parent.height - 44px;
        width: 100px;
        height: 32px;
        border-radius: 16px;
        background: log-btn-ta.has-hover ? Palette.active : Palette.elevated;
        border-width: 1px;
        border-color: log-btn-ta.has-hover ? Palette.border-focus : Palette.border;
        drop-shadow-blur: 12px;
        drop-shadow-color: Palette.shadow-md;
        drop-shadow-offset-y: -2px;
        animate background { duration: 120ms; }
        animate border-color { duration: 120ms; }
        HorizontalLayout {
            spacing: Sizes.space-2;
            alignment: center;
            Text {
                text: AppState.log-open ? "Hide Log" : "Activity";
                font-size: Sizes.font-xs;
                font-weight: 500;
                color: log-btn-ta.has-hover ? Palette.text : Palette.muted;
                vertical-alignment: center;
            }
            if AppState.log-error-count > 0 && !AppState.log-open: Rectangle {
                width: 16px;
                height: 16px;
                border-radius: 8px;
                background: Palette.red;
                Text {
                    text: AppState.log-error-count > 99 ? "+" : AppState.log-error-count;
                    font-size: 9px;
                    font-weight: 700;
                    color: Palette.on-accent;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }
        }
        log-btn-ta := TouchArea {
            mouse-cursor: MouseCursor.pointer;
            clicked => { root.log-toggle(); }
        }
    }

    // ── Doctor popup ─────────────────────────────────────────────────────
    if AppState.doctor-open: Rectangle {
        x: parent.width - 384px;
        y: 72px;
        width: 360px;
        height: 380px;
        border-radius: Sizes.radius-lg;
        background: Palette.surface;
        border-width: 1px;
        border-color: Palette.border;
        drop-shadow-blur: 24px;
        drop-shadow-color: Palette.shadow-lg;
        drop-shadow-offset-y: 6px;
        clip: true;

        VerticalLayout {
            // Header
            Rectangle {
                height: 48px;
                background: Palette.surface;
                HorizontalLayout {
                    padding-left: Sizes.space-5;
                    padding-right: Sizes.space-3;
                    alignment: space-between;
                    Text {
                        text: "Dependency Check";
                        font-size: Sizes.font-sm;
                        font-weight: 600;
                        color: Palette.text;
                        vertical-alignment: center;
                    }
                    Rectangle {
                        width: 24px;
                        height: 24px;
                        border-radius: 12px;
                        background: doc-close-ta.has-hover ? Palette.active : transparent;
                        animate background { duration: 100ms; }
                        y: (parent.height - self.height) / 2;
                        Text {
                            text: "\u{2715}";
                            font-size: 11px;
                            color: Palette.muted;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                        doc-close-ta := TouchArea {
                            mouse-cursor: MouseCursor.pointer;
                            clicked => { AppState.doctor-open = false; }
                        }
                    }
                }
                Rectangle {
                    y: parent.height - 1px;
                    height: 1px;
                    background: Palette.border-subtle;
                }
            }

            // Content
            ScrollView {
                VerticalLayout {
                    padding: Sizes.space-5;
                    spacing: Sizes.space-3;

                    if AppState.doctor-loading: Text {
                        text: "Scanning host tools\u{2026}";
                        font-size: Sizes.font-sm;
                        color: Palette.muted;
                    }

                    if !AppState.doctor-loading && AppState.doctor-text == "": Text {
                        text: "Open this panel to scan for required host tools (xorriso, mtools, qemu, etc.)";
                        font-size: Sizes.font-sm;
                        color: Palette.subtle;
                        wrap: word-wrap;
                    }

                    if !AppState.doctor-loading && AppState.doctor-text != "": Text {
                        text: AppState.doctor-text;
                        font-size: Sizes.font-sm;
                        color: Palette.text-secondary;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
