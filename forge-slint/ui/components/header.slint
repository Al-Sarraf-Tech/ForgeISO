import { Palette, Sizes } from "../theme.slint";

export component Header inherits Rectangle {
    in property <string>  job-phase;
    in property <float>   job-percent: -1.0;   // -1 = indeterminate
    in property <bool>    job-running: false;
    in property <string>  status-text;
    in property <bool>    status-is-error: false;
    in property <bool>    doctor-open: false;
    callback cancel();
    callback doctor-toggled();

    height: 64px;
    background: Palette.panel;

    // Bottom separator
    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: Palette.border;
    }

    HorizontalLayout {
        padding-left: 24px;
        padding-right: 24px;
        padding-top: 12px;
        padding-bottom: 12px;
        spacing: 16px;
        alignment: space-between;

        // Left: logo + wordmark
        HorizontalLayout {
            spacing: 12px;
            alignment: start;
            VerticalLayout {
                alignment: center;
                // Blue accent bar logo mark
                Rectangle {
                    width: 6px;
                    height: 36px;
                    border-radius: 3px;
                    background: @linear-gradient(180deg, Palette.accent 0%, #1a5cdb 100%);
                }
            }
            VerticalLayout {
                alignment: center;
                spacing: 2px;
                Text {
                    text: "ForgeISO";
                    font-size: Sizes.font-xl;
                    font-weight: 700;
                    color: Palette.text;
                }
                Text {
                    text: "ISO Pipeline Wizard";
                    font-size: Sizes.font-xs;
                    color: Palette.muted;
                }
            }
        }

        // Centre: status / progress
        HorizontalLayout {
            alignment: center;
            spacing: 10px;
            VerticalLayout {
                alignment: center;
                if job-running && job-percent >= 0.0: Rectangle {
                    // Determinate progress bar
                    width: 320px;
                    height: 6px;
                    border-radius: 3px;
                    background: Palette.border;
                    Rectangle {
                        width: parent.width * job-percent;
                        height: parent.height;
                        border-radius: parent.border-radius;
                        background: @linear-gradient(90deg, Palette.accent, #56a0f5);
                        animate width { duration: 200ms; easing: ease-out; }
                    }
                }
                if job-running && job-percent < 0.0: Rectangle {
                    // Indeterminate spinner pulse
                    width: 320px;
                    height: 6px;
                    border-radius: 3px;
                    background: Palette.border;
                    property <float> pos: 0.0;
                    Rectangle {
                        x: parent.width * pos;
                        width: 80px;
                        height: parent.height;
                        border-radius: parent.border-radius;
                        background: @linear-gradient(90deg, transparent, Palette.accent, transparent);
                    }
                    animate pos { duration: 1400ms; easing: linear; iteration-count: -1; }
                }
                if status-text != "" && !job-running: Text {
                    text: status-text;
                    font-size: Sizes.font-sm;
                    color: status-is-error ? Palette.red : Palette.green;
                }
                if job-running && job-phase != "": Text {
                    text: job-phase;
                    font-size: Sizes.font-sm;
                    color: Palette.muted;
                }
            }
        }

        // Right: cancel + doctor
        HorizontalLayout {
            spacing: 8px;
            alignment: end;

            // Doctor button
            Rectangle {
                width: 36px;
                height: 36px;
                border-radius: 8px;
                background: doctor-open ? Palette.accent : Palette.surface;
                border-width: 1px;
                border-color: doctor-open ? Palette.accent : Palette.border;
                animate background { duration: 150ms; }
                Text {
                    text: "🩺";
                    font-size: 16px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                TouchArea {
                    clicked => { root.doctor-toggled(); }
                }
            }

            // Cancel button (only when running)
            if job-running: Rectangle {
                width: 80px;
                height: 36px;
                border-radius: 8px;
                background: Palette.surface;
                border-width: 1px;
                border-color: Palette.red;
                Text {
                    text: "✕ Cancel";
                    font-size: Sizes.font-sm;
                    color: Palette.red;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                TouchArea {
                    clicked => { root.cancel(); }
                }
            }
        }
    }
}
