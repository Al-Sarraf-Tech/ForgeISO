import { Palette, Sizes } from "../theme.slint";

export component Header inherits Rectangle {
    in property <string>  job-phase;
    in property <float>   job-percent: -1.0;   // -1 = indeterminate
    in property <bool>    job-running: false;
    in property <string>  status-text;
    in property <bool>    status-is-error: false;
    in property <bool>    doctor-open: false;
    callback cancel();
    callback doctor-toggled();

    height: 64px;
    background: Palette.panel;

    // Bottom separator
    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: Palette.border;
    }

    HorizontalLayout {
        padding-left: 24px;
        padding-right: 24px;
        padding-top: 12px;
        padding-bottom: 12px;
        spacing: 16px;
        alignment: space-between;

        // Left: logo + wordmark
        HorizontalLayout {
            spacing: 12px;
            alignment: start;
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 6px;
                    height: 36px;
                    border-radius: 3px;
                    background: @linear-gradient(180deg, Palette.accent 0%, #1a5cdb 100%);
                }
            }
            VerticalLayout {
                alignment: center;
                spacing: 2px;
                Text {
                    text: "ForgeISO";
                    font-size: Sizes.font-xl;
                    font-weight: 700;
                    color: Palette.text;
                }
                Text {
                    text: "ISO Pipeline Wizard";
                    font-size: Sizes.font-xs;
                    color: Palette.muted;
                }
            }
        }

        // Centre: status / progress
        HorizontalLayout {
            alignment: center;
            spacing: 10px;
            VerticalLayout {
                alignment: center;

                // Determinate progress bar
                if job-running && job-percent >= 0.0: Rectangle {
                    width: 320px;
                    height: 6px;
                    border-radius: 3px;
                    background: Palette.border;
                    Rectangle {
                        width: parent.width * job-percent;
                        height: parent.height;
                        border-radius: parent.border-radius;
                        background: @linear-gradient(90deg, Palette.accent, #56a0f5);
                        animate width { duration: 200ms; easing: ease-out; }
                    }
                }

                // Indeterminate sweep — init triggers animation on creation
                if job-running && job-percent < 0.0: Rectangle {
                    width: 320px;
                    height: 6px;
                    border-radius: 3px;
                    background: Palette.border;
                    clip: true;

                    property <float> sweep: 0.0;
                    init => { sweep = 1.0; }
                    animate sweep { duration: 1600ms; easing: ease-in-out; iteration-count: -1; }

                    Rectangle {
                        x: (parent.width + 100px) * sweep - 100px;
                        width: 100px;
                        height: parent.height;
                        border-radius: parent.border-radius;
                        background: @linear-gradient(90deg, transparent, Palette.accent, transparent);
                    }
                }

                if status-text != "" && !job-running: Text {
                    text: status-text;
                    font-size: Sizes.font-sm;
                    color: status-is-error ? Palette.red : Palette.green;
                }
                if job-running && job-phase != "": Text {
                    text: job-phase;
                    font-size: Sizes.font-sm;
                    color: Palette.muted;
                }
            }
        }

        // Right: cancel + doctor
        HorizontalLayout {
            spacing: 8px;
            alignment: end;

            // Doctor button
            Rectangle {
                width: 36px;
                height: 36px;
                border-radius: 8px;
                background: doctor-open ? Palette.accent
                          : doc-ta.has-hover ? Palette.active
                          : Palette.elevated;
                border-width: 1px;
                border-color: doctor-open ? Palette.accent
                            : doc-ta.has-hover ? Palette.border-focus
                            : Palette.border;
                animate background { duration: 120ms; }
                animate border-color { duration: 120ms; }
                Text {
                    text: "🩺";
                    font-size: 16px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                doc-ta := TouchArea {
                    mouse-cursor: MouseCursor.pointer;
                    clicked => { root.doctor-toggled(); }
                }
            }

            // Cancel button (only when running)
            if job-running: Rectangle {
                width: 90px;
                height: 36px;
                border-radius: 8px;
                background: cancel-ta.has-hover ? rgba(248, 81, 73, 0.16) : rgba(248, 81, 73, 0.08);
                border-width: 1px;
                border-color: rgba(248, 81, 73, 0.5);
                animate background { duration: 100ms; }
                Text {
                    text: "✕  Cancel";
                    font-size: Sizes.font-sm;
                    font-weight: 600;
                    color: Palette.red;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                cancel-ta := TouchArea {
                    mouse-cursor: MouseCursor.pointer;
                    clicked => { root.cancel(); }
                }
            }
        }
    }
}
