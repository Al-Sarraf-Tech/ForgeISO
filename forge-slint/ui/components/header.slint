import { Palette, Sizes } from "../theme.slint";

export component Header inherits Rectangle {
    in property <string>  job-phase;
    in property <float>   job-percent: -1.0;
    in property <bool>    job-running: false;
    in property <string>  status-text;
    in property <bool>    status-is-error: false;
    in property <bool>    doctor-open: false;
    callback cancel();
    callback doctor-toggled();

    height: 68px;
    background: Palette.panel;

    // Bottom separator — gradient shimmer
    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: @linear-gradient(90deg,
            Palette.border, rgba(99, 102, 241, 0.25), Palette.border);
    }

    HorizontalLayout {
        padding-left: 32px;
        padding-right: 28px;
        spacing: 20px;
        alignment: space-between;

        // Left: gradient accent mark + wordmark
        HorizontalLayout {
            spacing: 16px;
            alignment: start;
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 6px;
                    height: 40px;
                    border-radius: 3px;
                    background: @linear-gradient(180deg, #6366f1 0%, #a855f7 100%);
                    drop-shadow-blur: 14px;
                    drop-shadow-color: rgba(99, 102, 241, 0.4);
                }
            }
            VerticalLayout {
                alignment: center;
                spacing: 3px;
                Text {
                    text: "ForgeISO";
                    font-size: Sizes.font-xl;
                    font-weight: 800;
                    color: Palette.text;
                    letter-spacing: -0.5px;
                }
                Text {
                    text: "Unattended ISO Builder";
                    font-size: Sizes.font-xs;
                    color: Palette.subtle;
                    letter-spacing: 1.2px;
                }
            }
        }

        // Centre: status / progress
        HorizontalLayout {
            alignment: center;
            spacing: 10px;
            VerticalLayout {
                alignment: center;

                // Determinate progress bar
                if job-running && job-percent >= 0.0: Rectangle {
                    width: 380px;
                    height: 8px;
                    border-radius: 4px;
                    background: Palette.elevated;
                    Rectangle {
                        width: parent.width * job-percent;
                        height: parent.height;
                        border-radius: parent.border-radius;
                        background: @linear-gradient(90deg, #6366f1, #818cf8);
                        drop-shadow-blur: 16px;
                        drop-shadow-color: rgba(99, 102, 241, 0.5);
                        animate width { duration: 200ms; easing: ease-out; }
                    }
                }

                // Indeterminate sweep
                if job-running && job-percent < 0.0: Rectangle {
                    width: 380px;
                    height: 8px;
                    border-radius: 4px;
                    background: Palette.elevated;
                    clip: true;
                    property <float> sweep: 0.0;
                    init => { sweep = 1.0; }
                    animate sweep { duration: 1600ms; easing: ease-in-out; iteration-count: -1; }
                    Rectangle {
                        x: (parent.width + 140px) * sweep - 140px;
                        width: 140px;
                        height: parent.height;
                        border-radius: parent.border-radius;
                        background: @linear-gradient(90deg, transparent, #6366f1, transparent);
                    }
                }

                if status-text != "" && !job-running: Text {
                    text: status-text;
                    font-size: Sizes.font-sm;
                    font-weight: 600;
                    color: status-is-error ? Palette.red : Palette.green;
                }
                if job-running && job-phase != "": Text {
                    text: job-phase;
                    font-size: Sizes.font-sm;
                    color: Palette.muted;
                }
            }
        }

        // Right: cancel + doctor
        HorizontalLayout {
            spacing: 10px;
            alignment: end;

            // Doctor button
            Rectangle {
                width: Sizes.btn-sm;
                height: Sizes.btn-sm;
                border-radius: Sizes.radius-sm;
                background: doctor-open ? Palette.accent
                          : doc-ta.has-hover ? Palette.active
                          : Palette.elevated;
                border-width: 1px;
                border-color: doctor-open ? Palette.accent
                            : doc-ta.has-hover ? Palette.border-focus
                            : Palette.border;
                drop-shadow-blur: doctor-open ? 20px : 0px;
                drop-shadow-color: doctor-open ? rgba(99, 102, 241, 0.45) : transparent;
                animate background { duration: 150ms; }
                animate border-color { duration: 150ms; }
                animate drop-shadow-blur { duration: 300ms; }
                Text {
                    text: "🩺";
                    font-size: 17px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                doc-ta := TouchArea {
                    mouse-cursor: MouseCursor.pointer;
                    clicked => { root.doctor-toggled(); }
                }
            }

            // Cancel button (only when running)
            if job-running: Rectangle {
                width: 110px;
                height: Sizes.btn-sm;
                border-radius: Sizes.radius-sm;
                background: cancel-ta.has-hover ? rgba(244, 63, 94, 0.2) : rgba(244, 63, 94, 0.08);
                border-width: 1px;
                border-color: rgba(244, 63, 94, 0.5);
                animate background { duration: 120ms; }
                Text {
                    text: "✕  Cancel";
                    font-size: Sizes.font-sm;
                    font-weight: 600;
                    color: Palette.red;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                cancel-ta := TouchArea {
                    mouse-cursor: MouseCursor.pointer;
                    clicked => { root.cancel(); }
                }
            }
        }
    }
}
