import { Palette, Sizes } from "../theme.slint";
import { FIconButton } from "design_system.slint";

export component Header inherits Rectangle {
    in property <string>  job-phase;
    in property <float>   job-percent: -1.0;   // -1 = indeterminate
    in property <bool>    job-running: false;
    in property <string>  status-text;
    in property <bool>    status-is-error: false;
    in property <bool>    doctor-open: false;
    callback cancel();
    callback doctor-toggled();

    height: 60px;
    background: Palette.panel;

    // Bottom shadow — subtle depth instead of hard border
    drop-shadow-blur: 8px;
    drop-shadow-color: Palette.shadow-sm;
    drop-shadow-offset-y: 2px;

    HorizontalLayout {
        padding-left: Sizes.space-6;
        padding-right: Sizes.space-6;
        padding-top: Sizes.space-3;
        padding-bottom: Sizes.space-3;
        spacing: Sizes.space-4;
        alignment: space-between;

        // Left: logo + wordmark
        HorizontalLayout {
            spacing: Sizes.space-3;
            alignment: start;
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 4px;
                    height: 32px;
                    border-radius: 2px;
                    background: @linear-gradient(180deg, Palette.accent 0%, #3366cc 100%);
                }
            }
            VerticalLayout {
                alignment: center;
                spacing: 1px;
                Text {
                    text: "ForgeISO";
                    font-size: Sizes.font-xl;
                    font-weight: 700;
                    color: Palette.text;
                    letter-spacing: -0.3px;
                }
                Text {
                    text: "Linux ISO Builder";
                    font-size: Sizes.font-2xs;
                    font-weight: 500;
                    color: Palette.subtle;
                    letter-spacing: 0.8px;
                }
            }
        }

        // Centre: status / progress
        HorizontalLayout {
            alignment: center;
            spacing: Sizes.space-2;
            VerticalLayout {
                alignment: center;

                // Determinate progress bar
                if job-running && job-percent >= 0.0: Rectangle {
                    width: 280px;
                    height: 4px;
                    border-radius: 2px;
                    background: Palette.border-subtle;
                    Rectangle {
                        width: parent.width * job-percent;
                        height: parent.height;
                        border-radius: parent.border-radius;
                        background: @linear-gradient(90deg, Palette.accent, Palette.accent-hover);
                        animate width { duration: 200ms; easing: ease-out; }
                    }
                }

                // Indeterminate sweep
                if job-running && job-percent < 0.0: Rectangle {
                    width: 280px;
                    height: 4px;
                    border-radius: 2px;
                    background: Palette.border-subtle;
                    clip: true;

                    property <float> sweep: 0.0;
                    init => { sweep = 1.0; }
                    animate sweep { duration: 1400ms; easing: ease-in-out; iteration-count: -1; }

                    Rectangle {
                        x: (parent.width + 80px) * sweep - 80px;
                        width: 80px;
                        height: parent.height;
                        border-radius: parent.border-radius;
                        background: @linear-gradient(90deg, transparent, Palette.accent, transparent);
                    }
                }

                if status-text != "" && !job-running: Text {
                    text: status-text;
                    font-size: Sizes.font-xs;
                    font-weight: 500;
                    color: status-is-error ? Palette.red : Palette.green;
                }
                if job-running && job-phase != "": Text {
                    text: job-phase;
                    font-size: Sizes.font-xs;
                    color: Palette.muted;
                }
            }
        }

        // Right: doctor + cancel
        HorizontalLayout {
            spacing: Sizes.space-2;
            alignment: end;

            FIconButton {
                icon: "+";
                active: doctor-open;
                clicked => { root.doctor-toggled(); }
            }

            if job-running: FIconButton {
                icon: "\u{2715}";
                variant: "destructive";
                clicked => { root.cancel(); }
            }
        }
    }
}
