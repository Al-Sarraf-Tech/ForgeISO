import { Palette, Sizes } from "../theme.slint";

component StepBadge inherits Rectangle {
    in property <string> num;
    in property <bool>   done: false;
    in property <bool>   current: false;
    in property <string> label;
    in property <string> sublabel;
    in property <bool>   clickable: false;
    in property <bool>   locked: false;
    callback clicked();

    property <bool> hovered: ta.has-hover;

    width: 170px;
    height: 56px;
    border-radius: Sizes.radius-md;
    background: current ? rgba(77, 142, 247, 0.06)
              : clickable && hovered ? rgba(255, 255, 255, 0.015)
              : transparent;
    border-width: current ? 1px : 0px;
    border-color: current ? rgba(77, 142, 247, 0.20) : transparent;
    animate background { duration: 150ms; }
    animate border-color { duration: 150ms; }

    HorizontalLayout {
        spacing: Sizes.space-3;
        alignment: start;
        padding-left: Sizes.space-3;
        padding-right: Sizes.space-3;

        // Badge circle
        Rectangle {
            width: 28px;
            height: 28px;
            border-radius: 14px;
            background: done ? Palette.green
                      : current ? Palette.accent
                      : Palette.elevated;
            border-width: done || current ? 0px : 1px;
            border-color: Palette.border;
            y: (parent.height - self.height) / 2;
            animate background { duration: 200ms; }

            Text {
                text: done ? "\u{2713}" : locked ? "\u{1F512}" : num;
                font-size: locked ? Sizes.font-2xs : Sizes.font-xs;
                font-weight: 700;
                color: done ? Palette.bg : current ? Palette.on-accent : Palette.muted;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 1px;
            Text {
                text: label;
                font-size: Sizes.font-sm;
                font-weight: current ? 600 : 400;
                color: done ? Palette.green
                     : current ? Palette.text
                     : clickable ? Palette.text-secondary
                     : Palette.muted;
                animate color { duration: 200ms; }
            }
            Text {
                text: sublabel;
                font-size: Sizes.font-2xs;
                color: current ? Palette.muted : Palette.subtle;
            }
        }
    }

    ta := TouchArea {
        enabled: clickable && !locked;
        mouse-cursor: clickable && !locked ? MouseCursor.pointer : MouseCursor.default;
        clicked => { root.clicked(); }
    }
}

export component StepBar inherits Rectangle {
    in property <int>  current-step: 1;
    in property <bool> step1-done: false;
    in property <bool> step2-done: false;
    in property <bool> step3-done: false;
    in property <bool> step4-done: false;
    in property <bool> job-running: false;
    callback step-clicked(int);

    height: 72px;
    background: Palette.panel;

    // Bottom border
    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: Palette.border-subtle;
    }

    HorizontalLayout {
        alignment: center;
        spacing: 0px;
        padding-top: Sizes.space-2;
        padding-bottom: Sizes.space-2;

        StepBadge {
            num: "1"; label: "Choose ISO"; sublabel: "Source image";
            done: step1-done; current: current-step == 1;
            clickable: !job-running && current-step != 1;
            locked: job-running && current-step != 1;
            clicked => { step-clicked(1); }
        }

        // Connector
        Rectangle {
            width: 48px;
            height: 2px;
            y: (parent.height - self.height) / 2;
            border-radius: 1px;
            background: step1-done ? Palette.accent : Palette.border-subtle;
            animate background { duration: 300ms; }
        }

        StepBadge {
            num: "2"; label: "Configure"; sublabel: "Installer settings";
            done: step2-done; current: current-step == 2;
            clickable: !job-running && step1-done && current-step != 2;
            locked: job-running && current-step != 2;
            clicked => { step-clicked(2); }
        }

        Rectangle {
            width: 48px;
            height: 2px;
            y: (parent.height - self.height) / 2;
            border-radius: 1px;
            background: step2-done ? Palette.accent : Palette.border-subtle;
            animate background { duration: 300ms; }
        }

        StepBadge {
            num: "3"; label: "Build"; sublabel: "Review and create";
            done: step3-done; current: current-step == 3;
            clickable: !job-running && step2-done && current-step != 3;
            locked: job-running && current-step != 3;
            clicked => { step-clicked(3); }
        }

        Rectangle {
            width: 48px;
            height: 2px;
            y: (parent.height - self.height) / 2;
            border-radius: 1px;
            background: step3-done ? Palette.accent : Palette.border-subtle;
            animate background { duration: 300ms; }
        }

        StepBadge {
            num: "4"; label: "Checks"; sublabel: "Optional validation";
            done: step4-done; current: current-step == 4;
            clickable: !job-running && step3-done && current-step != 4;
            locked: job-running && current-step != 4;
            clicked => { step-clicked(4); }
        }
    }
}
