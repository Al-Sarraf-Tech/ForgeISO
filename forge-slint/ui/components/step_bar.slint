import { Palette, Sizes } from "../theme.slint";

component StepBadge inherits Rectangle {
    in property <string> num;
    in property <bool>   done: false;
    in property <bool>   current: false;
    in property <string> label;
    in property <string> sublabel;
    in property <bool>   clickable: false;
    in property <bool>   locked: false;
    callback clicked();

    width: 174px;
    height: 64px;
    border-radius: Sizes.radius-lg;
    background: current ? rgba(47, 129, 247, 0.08) : transparent;
    border-width: current ? 1px : 0px;
    border-color: current ? rgba(47, 129, 247, 0.25) : transparent;

    HorizontalLayout {
        spacing: 10px;
        alignment: start;
        padding-left: 12px;
        padding-right: 12px;

        // Badge circle
        Rectangle {
            width: 30px;
            height: 30px;
            border-radius: 15px;
            background: done ? Palette.green : current ? Palette.accent : Palette.surface;
            border-width: 1.5px;
            border-color: done ? Palette.green : current ? Palette.accent : Palette.border;
            y: (parent.height - self.height) / 2;
            animate background { duration: 200ms; }
            animate border-color { duration: 200ms; }

            Text {
                text: done ? "✓" : locked ? "🔒" : num;
                font-size: locked ? Sizes.font-2xs : Sizes.font-sm;
                font-weight: 700;
                color: done ? #0d1117 : current ? #ffffff : Palette.muted;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text {
                text: label;
                font-size: Sizes.font-sm;
                font-weight: current ? 700 : 400;
                color: done ? Palette.green : current ? Palette.text : clickable ? Palette.text-secondary : Palette.muted;
                animate color { duration: 200ms; }
            }
            Text {
                text: sublabel;
                font-size: Sizes.font-xs;
                color: current ? Palette.muted : Palette.subtle;
            }
        }
    }

    if clickable && !locked: TouchArea {
        mouse-cursor: MouseCursor.pointer;
        clicked => { root.clicked(); }
    }
}

export component StepBar inherits Rectangle {
    in property <int>  current-step: 1;
    in property <bool> step1-done: false;
    in property <bool> step2-done: false;
    in property <bool> step3-done: false;
    in property <bool> step4-done: false;
    in property <bool> job-running: false;
    callback step-clicked(int);

    height: 84px;
    background: Palette.panel;

    // Bottom separator
    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: Palette.border;
    }

    HorizontalLayout {
        alignment: center;
        spacing: 0px;
        padding-top: 8px;
        padding-bottom: 8px;

        StepBadge {
            num: "1"; label: "Choose ISO"; sublabel: "Pick your source image";
            done: step1-done; current: current-step == 1;
            clickable: !job-running && current-step != 1;
            locked: job-running && current-step != 1;
            clicked => { step-clicked(1); }
        }

        // Connector 1→2
        Rectangle {
            width: 72px;
            height: 2px;
            y: (parent.height - self.height) / 2;
            border-radius: 1px;
            background: step1-done ? Palette.accent : Palette.border;
            animate background { duration: 300ms; }
        }

        StepBadge {
            num: "2"; label: "Configure"; sublabel: "Set up your install";
            done: step2-done; current: current-step == 2;
            clickable: !job-running && step1-done && current-step != 2;
            locked: job-running && current-step != 2;
            clicked => { step-clicked(2); }
        }

        // Connector 2→3
        Rectangle {
            width: 72px;
            height: 2px;
            y: (parent.height - self.height) / 2;
            border-radius: 1px;
            background: step2-done ? Palette.accent : Palette.border;
            animate background { duration: 300ms; }
        }

        StepBadge {
            num: "3"; label: "Review & Build"; sublabel: "Confirm and create";
            done: step3-done; current: current-step == 3;
            clickable: !job-running && step2-done && current-step != 3;
            locked: job-running && current-step != 3;
            clicked => { step-clicked(3); }
        }

        // Connector 3→4
        Rectangle {
            width: 72px;
            height: 2px;
            y: (parent.height - self.height) / 2;
            border-radius: 1px;
            background: step3-done ? Palette.accent : Palette.border;
            animate background { duration: 300ms; }
        }

        StepBadge {
            num: "4"; label: "Optional Checks"; sublabel: "Extra validation";
            done: step4-done; current: current-step == 4;
            clickable: !job-running && step3-done && current-step != 4;
            locked: job-running && current-step != 4;
            clicked => { step-clicked(4); }
        }
    }
}
