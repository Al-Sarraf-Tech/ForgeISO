import { Palette, Sizes } from "../theme.slint";
import { ScrollView } from "std-widgets.slint";
import { FIconButton, FBadge } from "design_system.slint";

export struct LogEntry {
    phase: string,
    message: string,
    level: int,       // 0=info 1=warn 2=error
    timestamp: string,
    percent: float,   // -1.0 = no bar; 0.0–1.0 = download/progress
}

export component LogPanel inherits Rectangle {
    in property <[LogEntry]> entries;
    in property <bool>       errors-only: false;
    in property <int>        error-count: 0;
    callback filter-toggled();
    callback close-clicked();

    width: 340px;
    background: Palette.panel;

    // Left separator
    Rectangle {
        x: 0;
        width: 1px;
        height: parent.height;
        background: Palette.border-subtle;
    }

    VerticalLayout {
        padding-left: 1px;

        // Header
        Rectangle {
            height: 42px;
            background: Palette.panel;
            HorizontalLayout {
                padding-left: Sizes.space-4;
                padding-right: Sizes.space-3;
                spacing: Sizes.space-2;
                alignment: space-between;
                VerticalLayout {
                    alignment: center;
                    HorizontalLayout {
                        spacing: Sizes.space-2;
                        alignment: start;
                        Text {
                            text: "Activity";
                            font-size: Sizes.font-sm;
                            font-weight: 600;
                            color: Palette.text;
                        }
                        if error-count > 0: FBadge {
                            text: error-count > 99 ? "99+" : error-count;
                            variant: "error";
                        }
                    }
                }
                HorizontalLayout {
                    spacing: Sizes.space-1;
                    alignment: end;
                    // Errors-only filter
                    Rectangle {
                        width: 56px;
                        height: 22px;
                        border-radius: 11px;
                        background: errors-only ? Palette.red
                                  : flt-ta.has-hover ? Palette.active
                                  : Palette.elevated;
                        border-width: 1px;
                        border-color: errors-only ? Palette.red : Palette.border;
                        animate background { duration: 120ms; }
                        Text {
                            text: "Errors";
                            font-size: Sizes.font-2xs;
                            font-weight: 500;
                            color: errors-only ? Palette.on-accent : Palette.muted;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                        flt-ta := TouchArea {
                            mouse-cursor: MouseCursor.pointer;
                            clicked => { filter-toggled(); }
                        }
                    }
                    // Close
                    Rectangle {
                        width: 22px;
                        height: 22px;
                        border-radius: 11px;
                        background: lp-close-ta.has-hover ? Palette.active : transparent;
                        animate background { duration: 100ms; }
                        Text {
                            text: "\u{2715}";
                            font-size: 11px;
                            color: Palette.muted;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                        lp-close-ta := TouchArea {
                            mouse-cursor: MouseCursor.pointer;
                            clicked => { close-clicked(); }
                        }
                    }
                }
            }
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Palette.border-subtle;
            }
        }

        // Log entries
        ScrollView {
            VerticalLayout {
                for entry in entries: VerticalLayout {
                    visible: !errors-only || entry.level == 2;

                    HorizontalLayout {
                        padding-left: Sizes.space-3;
                        padding-right: Sizes.space-2;
                        padding-top: Sizes.space-2;
                        padding-bottom: Sizes.space-2;
                        spacing: Sizes.space-2;

                        // Level indicator
                        Rectangle {
                            width: 2px;
                            min-height: 32px;
                            border-radius: 1px;
                            background: entry.level == 2 ? Palette.red
                                      : entry.level == 1 ? Palette.amber
                                      : rgba(77, 142, 247, 0.5);
                        }

                        VerticalLayout {
                            alignment: start;
                            spacing: 3px;
                            HorizontalLayout {
                                spacing: Sizes.space-2;
                                Text {
                                    text: entry.timestamp;
                                    font-size: Sizes.font-2xs;
                                    color: Palette.subtle;
                                }
                                Text {
                                    text: entry.phase;
                                    font-size: Sizes.font-2xs;
                                    font-weight: 600;
                                    color: entry.level == 2 ? Palette.red
                                         : entry.level == 1 ? Palette.amber
                                         : Palette.accent;
                                }
                            }
                            Text {
                                text: entry.message;
                                font-size: Sizes.font-xs;
                                color: entry.level == 2 ? rgba(240, 82, 75, 0.9)
                                     : entry.level == 1 ? rgba(227, 166, 44, 0.9)
                                     : Palette.text-secondary;
                                wrap: word-wrap;
                            }
                            // Progress bar
                            if entry.percent >= 0.0: VerticalLayout {
                                spacing: 2px;
                                Rectangle {
                                    height: 4px;
                                    border-radius: 2px;
                                    background: Palette.border-subtle;
                                    Rectangle {
                                        x: 0;
                                        width: parent.width * entry.percent;
                                        height: parent.height;
                                        border-radius: 2px;
                                        background: @linear-gradient(90deg, Palette.accent, Palette.accent-hover);
                                        animate width { duration: 200ms; easing: ease-out; }
                                    }
                                }
                                Text {
                                    text: Math.round(entry.percent * 100) + "%";
                                    font-size: Sizes.font-2xs;
                                    color: Palette.muted;
                                    horizontal-alignment: right;
                                }
                            }
                        }
                    }

                    // Subtle row separator
                    Rectangle {
                        height: 1px;
                        background: Palette.border-subtle;
                        opacity: 0.4;
                    }
                }
            }
        }
    }
}
